---
import { FESTIVAL_YEAR } from '../config/site.ts';

interface Props {
  lang: 'nl' | 'fr';
}
const { lang } = Astro.props;

const isNL = lang === 'nl';
---

<footer class="site-footer">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-6 text-sm">
    <div class="pt-4 text-sm flex justify-between items-center">
      <div>
        <a href="/nl" lang="nl" aria-current={lang === 'nl' ? 'true' : undefined}>NL</a>
        <span aria-hidden="true"> · </span>
        <a href="/fr" lang="fr" aria-current={lang === 'fr' ? 'true' : undefined}>FR</a>
      </div>
      <span>
        © Plazey {FESTIVAL_YEAR}
        <span aria-hidden="true"> · </span>
        <a href={isNL ? '/nl/over-plazey#contact' : '/fr/a-propos#contact'}>{isNL ? 'Contact' : 'Contact'}</a>
        <span aria-hidden="true"> · </span>
        <a href={isNL ? '/nl/privacyverklaring' : '/fr/politique-de-confidentialite'}>Privacy</a>
      </span>
      <p>Site door <a href="https://frederikvincx.com/" rel="external noopener" target="_blank">Impact Studio</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    /* Texture comes from the shared .site-outro wrapper so it spans Partners +
       Footer as one continuous background. */
    background: transparent;
    color: var(--color-text);
    position: relative;
  }
  .site-footer a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    /* Inline padding widens the tap area of these small, tightly packed links. */
    display: inline-block;
    padding: 0.375rem 0.25rem;
  }
  .site-footer a:hover {
    color: var(--color-orange);
  }
  .site-footer a[aria-current="true"] {
    background: var(--color-yellow);
    color: var(--color-maroon);
    font-weight: 700;
    border-radius: var(--radius-pill);
    padding: 2px 10px;
    text-decoration: none;
  }
</style>
