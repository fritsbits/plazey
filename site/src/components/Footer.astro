---
import { FESTIVAL_YEAR, FACEBOOK_URL, CONTACT_EMAIL } from '../config/site.ts';

interface Props {
  lang: 'nl' | 'fr';
}
const { lang } = Astro.props;

const isNL = lang === 'nl';
---

<footer>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 text-sm">
    <div class="flex gap-16 mb-10">
      <div class="footer-contact">
        <p class="text-xs uppercase tracking-wide text-gray-400 mb-2">Contact</p>
        <p>
          <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
          <span aria-hidden="true"> · </span>
          <a href="tel:+3224120050">02 412 00 50</a>
          <span aria-hidden="true"> · </span>
          <a href={FACEBOOK_URL} rel="external noopener" target="_blank">Facebook</a>
        </p>
      </div>

    </div>

    <div class="pt-4 border-t text-xs text-gray-400 flex justify-between items-center">
      <div>
        <a href="/nl" lang="nl" aria-current={lang === 'nl' ? 'true' : undefined}>NL</a>
        <span aria-hidden="true"> · </span>
        <a href="/fr" lang="fr" aria-current={lang === 'fr' ? 'true' : undefined}>FR</a>
      </div>
      <span>© Plazey {FESTIVAL_YEAR} · <a href={isNL ? '/nl/privacyverklaring' : '/fr/politique-de-confidentialite'}>Privacy</a></span>
      <p>Site door <a href="https://frederikvincx.com/" rel="external noopener" target="_blank">Impact Studio</a></p>
    </div>
  </div>

</footer>
