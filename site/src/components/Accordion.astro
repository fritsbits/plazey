---
interface Props {
  items: Array<{ question: string; answer: string }>;
  headingLevel?: 'h2' | 'h3';
}
const { items, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<dl class="accordion">
  {items.map((item) => (
    <details class="accordion-item">
      <summary class="accordion-summary">
        <Heading class="accordion-question">{item.question}</Heading>
        <span class="accordion-toggle" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line class="vertical" x1="12" y1="4" x2="12" y2="20"/>
          </svg>
        </span>
      </summary>
      <div class="accordion-answer"><p>{item.answer}</p></div>
    </details>
  ))}
</dl>
