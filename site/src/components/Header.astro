---
import { SITE_PHASE } from '../config/site.ts';

interface Props {
  lang: 'nl' | 'fr';
  currentPath?: string;
}
const { lang, currentPath = '' } = Astro.props;

const nlNav = SITE_PHASE === 'save-the-date'
  ? [
      { href: '/nl/praktisch', label: 'Praktisch' },
      { href: '/nl/over-plazey', label: 'Over Plazey' },
      { href: '/nl/vrijwilliger', label: 'Kom helpen' },
      { href: '/nl/stel-een-project-voor', label: 'Stel project voor' },
    ]
  : // reveal, live, and aftermovie all share the same nav links
    [
      { href: '/nl/programma', label: SITE_PHASE === 'aftermovie' ? 'Programma 2026' : 'Programma' },
      { href: '/nl/praktisch', label: 'Praktisch' },
      { href: '/nl/vrijwilliger', label: 'Kom helpen' },
      { href: '/nl/over-plazey', label: 'Over Plazey' },
    ];

const frNav = SITE_PHASE === 'save-the-date'
  ? [
      { href: '/fr/infos-pratiques', label: 'Pratique' },
      { href: '/fr/a-propos', label: 'À propos' },
      { href: '/fr/benevole', label: 'Viens aider' },
      { href: '/fr/propose-ton-projet', label: 'Propose un projet' },
    ]
  : // reveal, live, and aftermovie all share the same nav links
    [
      { href: '/fr/programme', label: SITE_PHASE === 'aftermovie' ? 'Programme 2026' : 'Programme' },
      { href: '/fr/infos-pratiques', label: 'Pratique' },
      { href: '/fr/benevole', label: 'Viens aider' },
      { href: '/fr/a-propos', label: 'À propos' },
    ];

const nav = lang === 'nl' ? nlNav : frNav;
const homeHref = lang === 'nl' ? '/nl' : '/fr';

// NL ↔ FR page pairs, so the language toggle keeps the reader on the same
// page instead of dropping them on the other home.
const nlToFr: Record<string, string> = {
  '/nl': '/fr',
  '/nl/programma': '/fr/programme',
  '/nl/praktisch': '/fr/infos-pratiques',
  '/nl/over-plazey': '/fr/a-propos',
  '/nl/vrijwilliger': '/fr/benevole',
  '/nl/stel-een-project-voor': '/fr/propose-ton-projet',
  '/nl/privacyverklaring': '/fr/politique-de-confidentialite',
};
const frToNl = Object.fromEntries(Object.entries(nlToFr).map(([nl, fr]) => [fr, nl]));
const nlHref = lang === 'nl' ? (currentPath || '/nl') : (frToNl[currentPath] ?? '/nl');
const frHref = lang === 'fr' ? (currentPath || '/fr') : (nlToFr[currentPath] ?? '/fr');

const navLabel = lang === 'fr' ? 'Navigation principale' : 'Hoofdnavigatie';
const menuLabel = 'Menu';
const logoAriaLabel = lang === 'fr' ? "Plazey — vers la page d'accueil" : 'Plazey — naar de startpagina';
const langLabel = lang === 'fr' ? 'Choix de la langue' : 'Taalkeuze';
---

<header class="site-nav">
  <nav aria-label={navLabel} class="site-nav-row">
    <a href={homeHref} aria-label={logoAriaLabel} class="site-nav-brand">Plazey</a>

    <button
      class="site-nav-toggle nav-toggle"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label={menuLabel}
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

    <ul id="nav-menu" role="list" class="site-nav-menu">
      {nav.map(({ href, label }) => (
        <li>
          <a
            class="site-nav-item"
            href={href}
            aria-current={currentPath.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <span class="site-nav-lang" role="group" aria-label={langLabel}>
      <a href={nlHref} lang="nl" hreflang="nl" aria-current={lang === 'nl' ? 'true' : undefined}>NL</a>
      <a href={frHref} lang="fr" hreflang="fr" aria-current={lang === 'fr' ? 'true' : undefined}>FR</a>
    </span>
  </nav>
</header>

<script>
  const headerEl = document.querySelector('header.site-nav') as HTMLElement;
  if (headerEl) {
    const setHeight = () => document.documentElement.style.setProperty('--header-height', `${headerEl.offsetHeight}px`);
    new ResizeObserver(setHeight).observe(headerEl);
    setHeight();
  }

  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('nav-menu') as HTMLElement;

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.toggleAttribute('data-open', !isOpen);
      if (!isOpen) {
        const firstLink = menu.querySelector('a') as HTMLAnchorElement;
        firstLink?.focus();
      }
    });

    menu.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.hasAttribute('data-open')) {
        toggle.setAttribute('aria-expanded', 'false');
        menu.removeAttribute('data-open');
        toggle.focus();
      }
    });

    for (const link of menu.querySelectorAll('a')) {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.removeAttribute('data-open');
      });
    }

    menu.addEventListener('keydown', (e) => {
      // Trap Tab only while the mobile menu is open as an overlay. On desktop
      // the menu is a plain always-visible nav row — wrapping focus there
      // locks keyboard users inside the nav (WCAG 2.1.2).
      if (e.key !== 'Tab' || !menu.hasAttribute('data-open')) return;
      const focusable = Array.from(
        menu.querySelectorAll('a, button')
      ) as HTMLElement[];
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last?.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first?.focus();
      }
    });
  }
</script>
