---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import ProgramCard from '../../../components/ProgramCard.astro';
import { getCollection } from 'astro:content';
import { SITE_PHASE, FACEBOOK_URL } from '../../../config/site.ts';

const allItems = await getCollection('programme');
const items = allItems
  .filter(e => e.id.startsWith('nl/') && !e.data.draft)
  .sort((a, b) => {
    const dayOrder: Record<string, number> = { friday: 0, saturday: 1, sunday: 2 };
    const dayDiff = (dayOrder[a.data.day] ?? 0) - (dayOrder[b.data.day] ?? 0);
    if (dayDiff !== 0) return dayDiff;
    return a.data.startTime.localeCompare(b.data.startTime);
  });

// Only show filter options that actually have programme items, so the
// filters can never lead to an empty result. Order follows these lists.
const presentDays = new Set<string>(items.map(e => e.data.day));
const presentTypes = new Set<string>(items.map(e => e.data.type));

const days = [
  { value: 'friday', label: 'Vrijdag 28 augustus' },
  { value: 'saturday', label: 'Zaterdag 29 augustus' },
  { value: 'sunday', label: 'Zondag 30 augustus' },
].filter(d => presentDays.has(d.value));

const types = [
  { value: 'concert', label: 'Concert' },
  { value: 'dans', label: 'Dans' },
  { value: 'film', label: 'Film' },
  { value: 'workshop', label: 'Workshop' },
  { value: 'kids', label: 'Kinderen' },
  { value: 'expo', label: 'Expo' },
  { value: 'theater', label: 'Theater' },
  { value: 'kermis', label: 'Kermis' },
  { value: 'off-stage', label: 'Off-stage' },
].filter(t => presentTypes.has(t.value));
---

<BaseLayout title="Programma" lang="nl" currentPath="/nl/programma">
  <section class="section hero-intro hero-green">
    <Container>
      <h1>Programma</h1>

      {SITE_PHASE === 'save-the-date' ? (
        <>
          <p>Het programma 2026 volgt binnenkort.</p>
          <p><a href={FACEBOOK_URL} rel="external noopener" target="_blank">Volg ons op Facebook voor de aankondiging.</a></p>
        </>
      ) : (
        <>
          <p>28–30 augustus 2026. Alles is gratis.</p>
          <p class="text-meta">Het uurrooster per act volgt binnenkort.</p>

          {SITE_PHASE === 'aftermovie' && (
            <div role="note" class="season-banner my-4 p-4 image-rounded" style="background: var(--color-surface-muted);">
              <p>Dit was het programma van Plazey 2026.</p>
            </div>
          )}

      <form id="filter-form" aria-label="Programma filteren" class="programme-filter">
        <fieldset class="filter-group filter-group--day">
          <legend class="filter-legend">Dag</legend>
          <div class="filter-pills">
            <label class="filter-pill">
              <input type="radio" name="dag" value="alle" checked />
              Alle dagen
            </label>
            {days.map(d => (
              <label class="filter-pill">
                <input type="radio" name="dag" value={d.value} />
                {d.label}
              </label>
            ))}
          </div>
        </fieldset>

        <fieldset class="filter-group filter-group--type">
          <legend class="filter-legend">Type</legend>
          <div class="filter-pills">
            <label class="filter-pill">
              <input type="radio" name="type" value="alle" checked />
              Alle types
            </label>
            {types.map(t => (
              <label class="filter-pill">
                <input type="radio" name="type" value={t.value} />
                {t.label}
              </label>
            ))}
          </div>
        </fieldset>
      </form>

      <div role="status" aria-live="polite" aria-atomic="true" id="filter-status" class="sr-only"></div>

      <div id="programme-list">
        {days.map(day => {
          const dayItems = items.filter(e => e.data.day === day.value);
          if (dayItems.length === 0) return null;
          return (
            <section data-day={day.value} aria-labelledby={`day-${day.value}`}>
              <h2 id={`day-${day.value}`} class="day-header">{day.label}</h2>
              <ul role="list" class="program-cards grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {dayItems.map(item => {
                  const cardProps = {
                    title: item.data.title,
                    startTime: item.data.startTime,
                    type: item.data.type,
                    href: `/nl/programma/${item.id.replace('nl/', '')}`,
                    lang: 'nl' as const,
                    ...(item.data.stage && { stage: item.data.stage }),
                    ...(item.data.endTime && { endTime: item.data.endTime }),
                    ...(item.data.curator && { curator: item.data.curator }),
                    ...(item.data.genre && { subtitle: item.data.genre }),
                    ...(item.data.description && { description: item.data.description }),
                  };
                  return (
                    <li data-type={item.data.type} data-day={item.data.day}>
                      <ProgramCard {...cardProps} />
                    </li>
                  );
                })}
              </ul>
            </section>
          );
        })}
      </div>

      <p id="empty-state" class="programme-empty" hidden>
        Niks gevonden met deze filters.
      </p>
        </>
      )}
    </Container>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('filter-form') as HTMLFormElement;
  const status = document.getElementById('filter-status') as HTMLElement;
  const emptyState = document.getElementById('empty-state') as HTMLElement;
  const list = document.getElementById('programme-list') as HTMLElement;

  // Index of what's actually programmed, read from the rendered cards.
  const cards2 = Array.from(list.querySelectorAll<HTMLElement>('li[data-type]'))
    .map(el => ({ type: el.dataset.type!, day: el.dataset.day! }));
  const allTypes = new Set(cards2.map(c => c.type));
  const allDays = new Set(cards2.map(c => c.day));

  // Faceted filtering: hide options that would yield zero results given the
  // other axis. Type pills adapt to the chosen day; day pills adapt to the
  // chosen type. Day and type are both single-select; a now-invalid selection
  // falls back to "alle" so we never strand the user on an empty result.
  function syncFacets() {
    const { dag } = getFilters();

    const typeAvail = dag === 'alle'
      ? allTypes
      : new Set(cards2.filter(c => c.day === dag).map(c => c.type));
    form.querySelectorAll<HTMLInputElement>('input[name="type"]').forEach(r => {
      if (r.value === 'alle') return;
      const ok = typeAvail.has(r.value);
      (r.closest('.filter-pill') as HTMLElement).hidden = !ok;
      if (!ok && r.checked) {
        r.checked = false;
        form.querySelector<HTMLInputElement>('input[name="type"][value="alle"]')!.checked = true;
      }
    });

    const selectedType = form.querySelector<HTMLInputElement>('input[name="type"]:checked')?.value ?? 'alle';
    const dayAvail = selectedType === 'alle'
      ? allDays
      : new Set(cards2.filter(c => c.type === selectedType).map(c => c.day));
    form.querySelectorAll<HTMLInputElement>('input[name="dag"]').forEach(r => {
      if (r.value === 'alle') return;
      const ok = dayAvail.has(r.value);
      (r.closest('.filter-pill') as HTMLElement).hidden = !ok;
      if (!ok && r.checked) {
        r.checked = false;
        form.querySelector<HTMLInputElement>('input[name="dag"][value="alle"]')!.checked = true;
      }
    });
  }

  function getFilters() {
    const data = new FormData(form);
    const dag = data.get('dag') as string || 'alle';
    const type = data.get('type') as string || 'alle';
    return { dag, type };
  }

  function applyFilters() {
    syncFacets();
    const { dag, type } = getFilters();
    const dayFilter = dag !== 'alle';
    const typeFilter = type !== 'alle';

    let visibleCount = 0;

    const cards = list.querySelectorAll<HTMLElement>('li[data-type]');
    cards.forEach(card => {
      const cardType = card.getAttribute('data-type');
      const cardDay = card.getAttribute('data-day');
      const dayMatch = !dayFilter || cardDay === dag;
      const typeMatch = !typeFilter || cardType === type;
      const visible = dayMatch && typeMatch;
      card.hidden = !visible;
      if (visible) visibleCount++;
    });

    // Hide a day's heading when none of its cards survive the active filters.
    // Scope to section[data-day] — cards also carry data-day, so a bare
    // [data-day] would match (and wrongly re-hide) every card too.
    const sections = list.querySelectorAll<HTMLElement>('section[data-day]');
    sections.forEach(section => {
      section.hidden = !section.querySelector('li[data-type]:not([hidden])');
    });

    emptyState.hidden = visibleCount > 0;
    list.hidden = visibleCount === 0;

    status.textContent = visibleCount === 0
      ? '0 items gevonden.'
      : `${visibleCount} ${visibleCount === 1 ? 'item' : 'items'} gevonden.`;

    const url = new URL(window.location.href);
    if (dag !== 'alle') url.searchParams.set('dag', dag); else url.searchParams.delete('dag');
    if (type !== 'alle') url.searchParams.set('type', type); else url.searchParams.delete('type');
    window.history.replaceState({}, '', url.toString());
  }

  function restoreFromURL() {
    const params = new URLSearchParams(window.location.search);
    const dag = params.get('dag');
    const type = params.get('type');
    if (dag) {
      const radio = form.querySelector<HTMLInputElement>(`input[name="dag"][value="${dag}"]`);
      if (radio) radio.checked = true;
    }
    if (type) {
      const radio = form.querySelector<HTMLInputElement>(`input[name="type"][value="${type}"]`);
      if (radio) radio.checked = true;
    }
    applyFilters();
  }

  form.addEventListener('change', applyFilters);
  restoreFromURL();
</script>
