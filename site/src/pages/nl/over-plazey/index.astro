---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import { Image } from 'astro:assets';
import dansPark from '../../../assets/images/dans-park.jpg';
---

<BaseLayout title="Over Plazey" lang="nl" currentPath="/nl/over-plazey">
  <section class="section hero-intro hero-green">
    <Container>
      <h1>Over Plazey</h1>
      <p class="opening">Dertig jaar buurtfeest in het Elisabethpark. Dit is wie het maakt.</p>
      <div class="cta-group">
        <a href="#contact" class="btn-primary">Neem contact op</a>
      </div>
    </Container>
  </section>

  <section aria-labelledby="het-verhaal" class="story-split">
    <div class="story-text">
      <h2 id="het-verhaal">Het verhaal</h2>
      <p>Plazey begon in 1992 als een klein muziekfeest voor de omwonenden van het Elisabethpark. Gratis, buiten, voor de buren. In de kern is het dat nog steeds.</p>
      <p>In het begin was het een klassiek zomerfestival, met bekende bandnamen die je ook op andere Vlaamse festivals zag. Dat veranderde. Plazey groeide naar de buurt toe. De muziek, de workshops, de eetstandjes: die komen nu van mensen die hier wonen en werken. Niet van elders gehaald, maar van hier.</p>
      <p>Achter het festival staan twee Brusselse gemeenschapscentra. De naam zegt het zelf: <strong>PLAtoo</strong> uit Koekelberg en <strong>ZEYp</strong> uit Ganshoren. Meer dan honderd vrijwilligers maken Plazey elk jaar waar.</p>
      <p>Sinds 2026 organiseert ook <strong>Vaart Kapoen</strong> (VK) mee. VK draait er een eigen podium.</p>
      <p>Sinds 2023 werken we eraan dat iedereen mee kan doen. Concreet: oordopjes aan de infostand en een programma in braille. We geven duidelijk aan wat al toegankelijk is en waar we momenteel nog aan werken.</p>
      <p>Plazey is er voor iedereen, en je moet je er welkom én veilig voelen. Altijd. Ongewenst gedrag hoort hier niet thuis, spreek gerust een medewerker aan als je iets opmerkt.</p>
    </div>
    <div class="story-image">
      <Image
        src={dansPark}
        alt="Mensen dansen buiten tussen de bomen in het Elisabethpark, verschillende leeftijden, feestelijke sfeer."
        widths={[800, 1200, 1600]}
        sizes="50vw"
      />
    </div>
  </section>

  <section aria-labelledby="de-centra" class="section">
    <Container>
      <h2 id="de-centra">De organisaties achter Plazey</h2>
      <div class="org-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
        <div class="org-card">
          <h3>GC De Platoo</h3>
          <p class="org-place">Koekelberg</p>
          <p>Geworteld in de buurt. De Platoo brengt mensen samen rond cultuur, ontmoeting en buurtwerk.</p>
          <ul role="list" class="org-links">
            <li>
              <a href="https://www.deplatoo.be" rel="external noopener" target="_blank">
                deplatoo.be
                <svg class="icon icon-sm" viewBox="0 0 24 24" aria-label="(opent in nieuw tabblad)">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </li>
            <li>
              <a href="https://maps.google.com/?q=Pantheonlaan+14,+1081+Koekelberg" rel="external noopener" target="_blank">
                Pantheonlaan 14, 1081 Koekelberg
                <svg class="icon icon-sm" viewBox="0 0 24 24" aria-label="(opent in Google Maps)">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </a>
            </li>
          </ul>
        </div>
        <div class="org-card">
          <h3>GC De Zeyp</h3>
          <p class="org-place">Ganshoren</p>
          <p>Verbindt buurtbewoners van de brede noordwestrand van Brussel. Met een programma dat de buurt weerspiegelt.</p>
          <ul role="list" class="org-links">
            <li>
              <a href="https://www.dezeyp.be" rel="external noopener" target="_blank">
                dezeyp.be
                <svg class="icon icon-sm" viewBox="0 0 24 24" aria-label="(opent in nieuw tabblad)">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </li>
            <li>
              <a href="https://maps.google.com/?q=Zeypstraat+47,+1083+Ganshoren" rel="external noopener" target="_blank">
                Zeypstraat 47, 1083 Ganshoren
                <svg class="icon icon-sm" viewBox="0 0 24 24" aria-label="(opent in Google Maps)">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </a>
            </li>
          </ul>
        </div>
        <div class="org-card">
          <h3>VK (De Vaartkapoen)</h3>
          <p class="org-place">Sint-Jans-Molenbeek</p>
          <p>Concertzaal en gemeenschapscentrum in Molenbeek. Sinds 2026 organiseert VK mee en draait er een eigen podium op Plazey.</p>
          <ul role="list" class="org-links">
            <li>
              <a href="https://www.vaartkapoen.be" rel="external noopener" target="_blank">
                vaartkapoen.be
                <svg class="icon icon-sm" viewBox="0 0 24 24" aria-label="(opent in nieuw tabblad)">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </li>
            <li>
              <a href="https://maps.google.com/?q=Schoolstraat+76,+1080+Sint-Jans-Molenbeek" rel="external noopener" target="_blank">
                Schoolstraat 76, 1080 Sint-Jans-Molenbeek
                <svg class="icon icon-sm" viewBox="0 0 24 24" aria-label="(opent in Google Maps)">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <aside id="contact" aria-labelledby="contact-heading" class="callout section">
    <Container>
      <h2 id="contact-heading">Neem contact op.</h2>
      <p>Vraag, idee, of iets anders? Laat het weten.</p>

      <div class="cta-form">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          class="flex flex-col gap-6"
        >
            <input type="hidden" name="form-name" value="contact" />
            <input type="hidden" name="origin" value="over-plazey" />
            <input type="hidden" name="lang" value="nl" />

            <div class="form-field">
              <label for="contact-naam">Naam</label>
              <input
                type="text"
                id="contact-naam"
                name="naam"
                required
                autocomplete="name"
                maxlength="200"
              />
            </div>

            <div class="form-field">
              <label for="contact-email">E-mailadres</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                autocomplete="email"
                maxlength="254"
              />
            </div>

            <div class="form-field">
              <label for="contact-bericht">Bericht</label>
              <textarea
                id="contact-bericht"
                name="bericht"
                rows="4"
                required
                maxlength="2000"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary self-start">Stuur je bericht</button>
          </form>
      </div>
    </Container>
  </aside>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!submitBtn) return;
      const originalText = submitBtn.textContent ?? '';
      submitBtn.disabled = true;
      submitBtn.textContent = 'Bezig…';
      try {
        const response = await fetch(window.location.pathname, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
        });
        if (response.ok) {
          const aside = form.closest<HTMLElement>('aside');
          if (!aside) return;
          aside.classList.add('contact-leaving');
          setTimeout(() => {
            aside.innerHTML = `<div class="max-w-4xl mx-auto px-4 sm:px-6"><div class="contact-success" role="status" tabindex="-1"><svg class="contact-success-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg><p class="contact-success-heading">Je bericht is<br>onderweg.</p></div></div>`;
            aside.classList.remove('contact-leaving');
            aside.querySelector<HTMLElement>('[role="status"]')?.focus();
          }, 280);
        } else {
          throw new Error('server error');
        }
      } catch {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        let errorEl = form.querySelector<HTMLParagraphElement>('.form-error');
        if (!errorEl) {
          errorEl = document.createElement('p');
          errorEl.className = 'form-error';
          errorEl.setAttribute('role', 'alert');
          submitBtn.insertAdjacentElement('beforebegin', errorEl);
        }
        errorEl.textContent = '';
        errorEl.append('Er ging iets mis. Probeer het opnieuw of stuur een mail naar ');
        const mailLink = document.createElement('a');
        mailLink.href = 'mailto:info@plazey.be';
        mailLink.textContent = 'info@plazey.be';
        errorEl.append(mailLink, '.');
      }
    });
  }

</script>

<style is:global>
  .contact-leaving {
    opacity: 0;
    transform: scale(0.98);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .contact-success {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 14rem;
    padding: 3rem 0;
    gap: 0.75rem;
  }

  .contact-success-icon {
    width: 2rem;
    height: 2rem;
    color: var(--color-coral);
    opacity: 0;
    animation: success-arrive 0.4s ease-out forwards;
  }

  .contact-success-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.1;
    color: var(--color-text);
    margin: 0;
    opacity: 0;
    animation: success-arrive 0.5s 0.1s ease-out forwards;
  }

  @keyframes success-arrive {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-success-icon,
    .contact-success-heading { animation: none; opacity: 1; }
    .contact-leaving { transition: none; opacity: 1; transform: none; }
  }
</style>
