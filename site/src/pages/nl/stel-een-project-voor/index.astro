---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Accordion from '../../../components/Accordion.astro';
import { Image } from 'astro:assets';
import concertRapBasiliek from '../../../assets/images/concert-rap-basiliek.jpg';
import parkLaanKunst from '../../../assets/images/park-laan-kunst.jpg';
import dansPark from '../../../assets/images/dans-park.jpg';
import muziekTromClose from '../../../assets/images/muziek-trom-close.jpg';

const voorbeelden = [
  {
    src: concertRapBasiliek,
    alt: 'Twee MC\'s op een openluchtpodium voor een dicht publiek, met de Basiliek van Koekelberg op de achtergrond.',
    titel: 'Buurtbands op een groot podium',
    tekst: 'Club 1030 programmeerde vier jonge bands uit de buurt.',
  },
  {
    src: parkLaanKunst,
    alt: 'Bomenlaan in Elisabethpark met kunstwerken die aan de takken hangen, bezoekers wandelen eronder.',
    titel: 'Kunst aan de bomen',
    tekst: 'Arborescences gaf elke kunstenaar één boom in het park.',
  },
  {
    src: dansPark,
    alt: 'Groep mensen in verschillende leeftijden die samen dansen tussen de bomen van het park.',
    titel: 'Dans voor iedereen',
    tekst: 'Etage Tropical gaf workshops open voor mensen met en zonder beperking.',
  },
  {
    src: muziekTromClose,
    alt: 'Close-up van een bass drum die wordt aangeslagen, een trompetspeler erachter.',
    titel: 'Percussie uit de buurt',
    tekst: 'Fanfakids trok met trommels en trompet door het park.',
  },
];

const faqItems = [
  { question: 'Ik heb geen organisatie. Mag ik toch iets voorstellen?', answer: 'Ja. Individuen zijn welkom.' },
  { question: 'Moet ik Nederlands of Frans spreken?', answer: 'Nee. Plazey is meertalig. Dien in in de taal die voor jou werkt.' },
  { question: 'Krijg ik betaald?', answer: 'We werken met een beperkt budget. Zet in je voorstel wat je nodig hebt. We antwoorden eerlijk wat we wel en niet kunnen dekken.' },
  { question: 'Tot wanneer kan ik voorstellen?', answer: 'We plannen het programma in de winter. Hoe vroeger je indient, hoe groter de kans.' },
  { question: 'Is er een limiet op wat er kan?', answer: 'Bijna niet. Muziek, dans, theater, film, workshop, eten, sport, kunst, kinderen. Stuur het en we praten erover.' },
  { question: 'Wat gebeurt er met mijn voorstel?', answer: 'We lezen elk voorstel en nemen contact op. Soms vragen we een gesprek. Soms passen we je idee samen aan.' },
];
---

<BaseLayout title="Stel een project voor" lang="nl" currentPath="/nl/stel-een-project-voor">
  <section class="section">
    <Container>
      <h1>Stel een project voor</h1>
      <p class="opening">Plazey wordt mee gemaakt door de buurt. Buurtbewoners, lokale artiesten en kleine organisaties zetten elk jaar een deel van het programma op. Misschien jij ook.</p>
      <div class="cta-group">
        <a href="#stuur-voorstel" class="btn-ghost">Stel je project voor</a>
      </div>
    </Container>
  </section>

  <section aria-labelledby="voorbeelden-heading" class="section">
    <Container>
      <h2 id="voorbeelden-heading">Wat hebben buurtbewoners al gedaan?</h2>

      <ul role="list" class="voorbeelden-grid grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-12 mt-8">
        {voorbeelden.map((v) => (
          <li class="voorbeeld-card">
            <Image
              src={v.src}
              alt={v.alt}
              widths={[400, 700]}
              sizes="(max-width: 640px) 100vw, 50vw"
              class="w-full aspect-image object-cover image-rounded"
            />
            <h3>{v.titel}</h3>
            <p>{v.tekst}</p>
          </li>
        ))}
      </ul>

      <p class="mt-6">Ook op Plazey gedaan: rondleidingen door Koekelberg, een leesclub voor kinderen, een inclusief theaterlab, een koor open voor iedereen, films van Brusselse makers, een literaire apéro.</p>
      <p>Je ziet het: muziek, dans, theater, film, lezen, eten, sport. Klein of groot. Voor één middag of voor drie dagen.</p>
      <div class="cta-group">
        <a href="#stuur-voorstel" class="btn-ghost">Stel je project voor</a>
      </div>
    </Container>
  </section>

  <section aria-labelledby="vragen-projectvoorstel" class="section">
    <Container>
      <h2 id="vragen-projectvoorstel">Vragen</h2>
      <Accordion items={faqItems} />
    </Container>
  </section>

  <aside id="stuur-voorstel" aria-labelledby="stuur-voorstel-heading" class="callout section">
    <Container>
      <h2 id="stuur-voorstel-heading">Stel je project voor.</h2>
      <p>We lezen elk voorstel en nemen contact op.</p>

      <div class="cta-form">
        <form
          name="project-voorstel"
          method="POST"
          data-netlify="true"
          class="flex flex-col gap-6"
        >
            <input type="hidden" name="form-name" value="project-voorstel" />

            <div class="form-field">
              <label for="naam-pv">Naam</label>
              <input
                type="text"
                id="naam-pv"
                name="naam"
                required
                autocomplete="name"
                maxlength="200"
              />
            </div>

            <div class="form-field">
              <label for="email-pv">E-mailadres</label>
              <input
                type="email"
                id="email-pv"
                name="email"
                required
                autocomplete="email"
                maxlength="254"
              />
            </div>

            <div class="form-field">
              <label for="project-omschrijving">Wat is je idee?</label>
              <textarea
                id="project-omschrijving"
                name="omschrijving"
                rows="4"
                required
                maxlength="2000"
              ></textarea>
            </div>

            <div class="form-field">
              <label for="project-nodig">Wat heb je nodig? <span style="font-weight: 400; color: var(--color-text-muted)">(ruimte, materiaal, tijd)</span></label>
              <textarea
                id="project-nodig"
                name="nodig"
                rows="3"
                maxlength="1000"
              ></textarea>
            </div>

            <fieldset class="flex flex-col gap-2">
              <legend class="font-semibold text-sm">Voor welke dag denk je?</legend>
              <label class="flex items-center gap-2"><input type="radio" name="dag" value="vrijdag" /> Vrijdag</label>
              <label class="flex items-center gap-2"><input type="radio" name="dag" value="zaterdag" /> Zaterdag</label>
              <label class="flex items-center gap-2"><input type="radio" name="dag" value="zondag" /> Zondag</label>
              <label class="flex items-center gap-2"><input type="radio" name="dag" value="weet-nog-niet" /> Weet ik nog niet</label>
            </fieldset>

            <p class="text-sm" style="color: var(--color-text-muted)">Nog niet alles rond? Dat geeft niet. Stuur wat je hebt, we denken mee.</p>
            <button type="submit" class="btn-primary self-start">Stuur je voorstel</button>
          </form>
      </div>
    </Container>
  </aside>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('form[name="project-voorstel"]');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!submitBtn) return;
      const originalText = submitBtn.textContent ?? '';
      submitBtn.disabled = true;
      submitBtn.textContent = 'Bezig…';
      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
        });
        if (response.ok) {
          const successEl = document.createElement('p');
          successEl.className = 'py-4 font-semibold';
          successEl.setAttribute('role', 'status');
          successEl.setAttribute('tabindex', '-1');
          successEl.textContent = 'Bedankt voor je voorstel! We nemen zo snel mogelijk contact op.';
          form.replaceWith(successEl);
          successEl.focus();
        } else {
          throw new Error('server error');
        }
      } catch {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        let errorEl = form.querySelector<HTMLParagraphElement>('.form-error');
        if (!errorEl) {
          errorEl = document.createElement('p');
          errorEl.className = 'form-error';
          errorEl.setAttribute('role', 'alert');
          submitBtn.insertAdjacentElement('beforebegin', errorEl);
        }
        errorEl.textContent = 'Er ging iets mis. Probeer het opnieuw of stuur een mail naar info@plazey.be.';
      }
    });
  }
</script>
