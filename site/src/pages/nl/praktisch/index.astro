---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Accordion from '../../../components/Accordion.astro';
import { Image } from 'astro:assets';
import { FESTIVAL_DATES_NL, FESTIVAL_LOCATION } from '../../../config/site';
import etenFoodkraam from '../../../assets/images/eten-foodkraam.jpg';
import kidsZandbak from '../../../assets/images/kids-zandbak.jpg';
import kindOordoppen from '../../../assets/images/kind-oordoppen.jpg';

const faqItems = [
  { question: 'Is Plazey echt gratis?', answer: 'Ja. Geen tickets, geen toegangsprijs. Plazey is gratis voor iedereen, al sinds 1992.' },
  { question: 'Mag ik mijn eigen eten en drinken meebrengen?', answer: 'Ja. Eigen eten en drinken zijn altijd welkom. Kraantjeswater haal je gratis aan de bar.' },
  { question: 'Is er een cloakroom of bagageruimte?', answer: 'Nee. Kom met zo weinig bagage als mogelijk.' },
  { question: 'Hoe laat begint en eindigt het festival?', answer: 'Vrijdag van 14:00 tot middernacht. Zaterdag en zondag van 14:00 tot 22:00.' },
  { question: 'Wat als het regent?', answer: 'Plazey gaat altijd door, ook als het regent. Het park heeft overdekte plekken. Neem een regenjas mee voor de zekerheid.' },
  { question: 'Kan ik er met een rolstoel of kinderwagen naartoe?', answer: 'Ja. De hoofdpaden zijn vlak en toegankelijk voor rolstoelen en wandelwagens. Niet alle kleinere paden zijn toegankelijk.' },
];
---

<BaseLayout title="Praktisch" lang="nl" currentPath="/nl/praktisch" bodyClass="page-yellow">
  <section class="section hero-intro hero-green">
    <Container>
      <h1>Alles wat je moet weten voor je komt.</h1>
      <p class="text-date">
        {FESTIVAL_DATES_NL}<span class="meta-sep" aria-hidden="true"></span>{FESTIVAL_LOCATION}
      </p>
      <p class="text-free"><span class="text-free-mark">Gratis voor iedereen.</span></p>
    </Container>
  </section>

  <Container>
    <nav class="hero-anchors hero-anchors--plain" aria-label="Op deze pagina">
      <a href="#bereikbaarheid" class="hero-anchor" style="--anchor-bg: var(--color-yellow);">
        <span class="hero-anchor-label">Bereikbaarheid</span>
      </a>
      <a href="#eten-en-drinken" class="hero-anchor hero-anchor--dark" style="--anchor-bg: var(--color-green);">
        <span class="hero-anchor-label">Eten &amp; drinken</span>
      </a>
      <a href="#toegankelijkheid" class="hero-anchor" style="--anchor-bg: var(--color-yellow);">
        <span class="hero-anchor-label">Toegankelijkheid</span>
      </a>
      <a href="#kinderen" class="hero-anchor hero-anchor--dark" style="--anchor-bg: var(--color-green);">
        <span class="hero-anchor-label">Kinderen</span>
      </a>
      <a href="#faq" class="hero-anchor" style="--anchor-bg: var(--color-yellow);">
        <span class="hero-anchor-label">Veelgestelde vragen</span>
      </a>
    </nav>
  </Container>

  <div>
    <Container>
      <section id="bereikbaarheid" aria-labelledby="heading-bereikbaarheid" class="page-section">
        <h2 id="heading-bereikbaarheid" class="h2-display">Vijf minuten wandelen van <span class="underline-mustard">metro Simonis</span></h2>

        <div class="transport-grid">
          <div class="transport-card">
            <span class="mode-icon" aria-hidden="true">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="12" width="44" height="34" rx="7" fill="var(--color-orange)" stroke="var(--color-text)" stroke-width="2.5"/>
                <rect x="14" y="18" width="14" height="10" rx="2" fill="var(--color-surface)" stroke="var(--color-text)" stroke-width="2"/>
                <rect x="32" y="18" width="14" height="10" rx="2" fill="var(--color-surface)" stroke="var(--color-text)" stroke-width="2"/>
                <text x="30" y="42" text-anchor="middle" style="font-family: var(--font-heading)" font-size="14" fill="var(--color-text)">M</text>
                <circle cx="18" cy="50" r="3.5" fill="var(--color-text)"/>
                <circle cx="42" cy="50" r="3.5" fill="var(--color-text)"/>
              </svg>
            </span>
            <h3 class="mode">Metro</h3>
            <p>Lijn 2 of 6, halte Simonis/Elisabeth. Vijf minuten wandelen naar het park. Het metrostation heeft een lift.</p>
          </div>

          <div class="transport-card">
            <span class="mode-icon" aria-hidden="true">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <circle cx="14" cy="42" r="11" fill="var(--color-sage)" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="46" cy="42" r="11" fill="var(--color-sage)" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="14" cy="42" r="3" fill="var(--color-text)"/>
                <circle cx="46" cy="42" r="3" fill="var(--color-text)"/>
                <path d="M14 42 L26 22 L40 42 M26 22 L42 22" stroke="var(--color-text)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="42" cy="20" r="2.5" fill="var(--color-text)"/>
              </svg>
            </span>
            <h3 class="mode">Fiets</h3>
            <p>Onbewaakte stalling op het terrein. Breng een slot mee.</p>
          </div>

          <div class="transport-card">
            <span class="mode-icon" aria-hidden="true">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 40 L6 30 L14 22 L46 22 L54 30 L54 40 Z" fill="var(--color-yellow)" stroke="var(--color-text)" stroke-width="2.5" stroke-linejoin="round"/>
                <path d="M14 22 L20 14 L40 14 L46 22" fill="var(--color-yellow)" stroke="var(--color-text)" stroke-width="2.5" stroke-linejoin="round"/>
                <line x1="30" y1="14" x2="30" y2="22" stroke="var(--color-text)" stroke-width="2"/>
                <circle cx="16" cy="44" r="4" fill="var(--color-text)"/>
                <circle cx="44" cy="44" r="4" fill="var(--color-text)"/>
              </svg>
            </span>
            <h3 class="mode">Auto</h3>
            <p>Betalend rondom het park, of in de ondergrondse parking Indigoneo. Adres: Eugène Simonisplein 24, 1081 Koekelberg.</p>
          </div>

          <div class="transport-card card-wide">
            <span class="mode-icon" aria-hidden="true">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="8" width="44" height="40" rx="6" fill="var(--color-green)" stroke="var(--color-text)" stroke-width="2.5"/>
                <rect x="13" y="14" width="14" height="9" rx="1.5" fill="var(--color-surface)" stroke="var(--color-text)" stroke-width="1.5"/>
                <rect x="33" y="14" width="14" height="9" rx="1.5" fill="var(--color-surface)" stroke="var(--color-text)" stroke-width="1.5"/>
                <rect x="13" y="27" width="34" height="6" rx="1" fill="var(--color-yellow)" stroke="var(--color-text)" stroke-width="1.5"/>
                <circle cx="18" cy="52" r="3.5" fill="var(--color-text)"/>
                <circle cx="42" cy="52" r="3.5" fill="var(--color-text)"/>
              </svg>
            </span>
            <h3 class="mode">Tram &amp; bus</h3>
            <p>Halte Elisabethpark of Simonis/Elisabeth.</p>
            <ul>
              <li>Tram 9 of 19</li>
              <li>Bus MIVB 13, 87, N16, halte Elisabethpark</li>
              <li>Bus MIVB 49 of 53, halte Vrijheid</li>
              <li>De Lijn 212, 213, 214, 355, halte Elisabethpark</li>
            </ul>
          </div>

          <aside class="transport-help" aria-label="Hulp nodig?">
            <p class="transport-help-question">Hulp nodig om van de metro naar het terrein te komen?</p>
            <a href="#contact" class="transport-help-link" data-topic="bereikbaarheid">Laat het ons weten <span class="arrow" aria-hidden="true">→</span></a>
          </aside>
        </div>
      </section>

      <section id="eten-en-drinken" aria-labelledby="heading-eten" class="split-section split--image-right paper-sheet paper-sheet--surface-muted paper-sheet--tilt-l">
        <div class="split-image">
          <figure class="snapshot">
            <Image
              src={etenFoodkraam}
              alt="Een eetstand onder een tent op Plazey: twee vrouwen bereiden en serveren eten, één heft een beker op."
              widths={[600, 960, 1280]}
              sizes="(max-width: 767px) 100vw, 50vw"
            />
            <figcaption>De standhouders komen uit de buurt.</figcaption>
          </figure>
        </div>
        <div class="split-text eten-content">
          <h2 id="heading-eten" class="h2-display"><span class="underline-mustard">Breng je eigen picknick,</span> of koop aan de bar</h2>

          <div class="eten-menu">
            <p class="drinks-free">Plat water is <span>gratis</span>.</p>
            <ul class="drinks-list">
              <li><span class="drink">Fris</span><span class="price">€ 2 tot € 3</span></li>
              <li><span class="drink">Bier</span><span class="price">€ 3 tot € 4</span></li>
              <li><span class="drink">Wijn &amp; bubbels</span><span class="price">€ 4 tot € 5</span></li>
            </ul>
            <p class="drinks-note">Wijn en bubbels per glas. Cash wordt aanvaard.</p>
          </div>

          <p>Ons bier komt van Brusselse brouwers. Er is ook alcoholvrij bier en schuimwijn.</p>
          <p>Naast dranken zijn er eetstandjes. We kiezen bewust voor buurtbewoners, lokale horecazaken en start-ups als standhouders. Wie er dit jaar staat, vind je binnenkort op deze pagina.</p>
        </div>
      </section>

      <section id="toegankelijkheid" aria-labelledby="heading-toegankelijkheid" class="page-section page-section--no-rule">
        <h2 id="heading-toegankelijkheid" class="h2-display"><span class="underline-mustard">Iedereen welkom</span>, ook als je hulp nodig hebt</h2>

        <div class="col-grid-2">
          <div class="access-cat">
            <h3 class="label">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="30" cy="30" r="24" fill="var(--color-orange)" stroke="var(--color-text)" stroke-width="2.5"/>
                <path d="M22 26 Q22 18 30 18 Q38 18 38 26 L38 36 Q38 42 32 42 Q28 42 28 38" stroke="var(--color-text)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M42 22 Q46 26 46 30 Q46 34 42 38" stroke="var(--color-text)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              </svg>
              Gehoor
            </h3>
            <ul>
              <li><strong>Oordopjes:</strong> te verkrijgen aan de infostand.</li>
              <li>Andere vragen over gehoor? <a href="#contact" data-topic="toegankelijkheid">Stel je vraag</a>, we zoeken het voor je uit.</li>
            </ul>
          </div>

          <div class="access-cat">
            <h3 class="label">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="30" cy="30" r="24" fill="var(--color-sage)" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="28" cy="16" r="3" fill="var(--color-text)"/>
                <path d="M28 21 L28 33 L40 33" stroke="var(--color-text)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="32" cy="40" r="9" fill="none" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="32" cy="40" r="2" fill="var(--color-text)"/>
              </svg>
              Mobiliteit
            </h3>
            <ul>
              <li><strong>Vlakke hoofdpaden:</strong> toegankelijk voor rolstoelen en wandelwagens.</li>
              <li><strong>Aangepaste toiletten:</strong> voor rolstoelgebruikers.</li>
              <li><strong>Metro Simonis heeft een lift:</strong> rolstoel-toegankelijk.</li>
            </ul>
          </div>

          <div class="access-cat">
            <h3 class="label">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="30" cy="30" r="24" fill="var(--color-yellow)" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="30" cy="20" r="2.5" fill="var(--color-text)"/>
                <path d="M30 27 L30 42" stroke="var(--color-text)" stroke-width="4" stroke-linecap="round"/>
              </svg>
              Zorg &amp; info
            </h3>
            <ul>
              <li><strong>Hulp bij dagelijkse dingen:</strong> vrijwilligers helpen je bij eten, drinken, toilet of de weg vinden op het terrein. <a href="#contact" data-topic="toegankelijkheid" data-prefill="adl">Vraag het vooraf aan.</a></li>
              <li><strong>Programma en dranklijst:</strong> in braille of in gewone druk, aan de infostand.</li>
              <li><strong>Rustige ruimte:</strong> voor wie even weg wil van het lawaai.</li>
            </ul>
          </div>

          <div class="access-cat">
            <h3 class="label">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M30 8 L48 14 L48 28 Q48 42 30 52 Q12 42 12 28 L12 14 Z" fill="var(--color-green)" stroke="var(--color-text)" stroke-width="2.5" stroke-linejoin="round"/>
                <path d="M22 30 L28 36 L40 22" stroke="var(--color-surface)" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Veiligheid
            </h3>
            <ul>
              <li>Zie je dat iemand lastiggevallen wordt? Vraag gewoon: "Gaat het?"</li>
              <li>Voel je je zelf niet veilig? Spreek een medewerker aan, herkenbaar aan een kleurrijke t-shirt met het Plazey-logo.</li>
              <li>We luisteren zonder oordeel en zoeken samen uit wat er nodig is.</li>
            </ul>
          </div>
        </div>

        <figure class="snapshot snapshot--tilt-l snapshot--solo">
          <Image
            src={kindOordoppen}
            alt="Een kind met gehoorbescherming op de schouders van een ouder, kijkend naar een optreden."
            widths={[520, 780]}
            sizes="(max-width: 559px) 100vw, 492px"
          />
          <figcaption>Soms wordt het te luid. Oordopjes helpen.</figcaption>
        </figure>

        <div class="callout-inline">
          <p>Heb je een vraag of nodig je hulp? <a href="#contact" data-topic="toegankelijkheid">Stel je vraag.</a></p>
        </div>
      </section>

    </Container>

    <section id="kinderen" aria-labelledby="heading-kinderen" class="split-section split--image-left paper-sheet paper-sheet--beige paper-sheet--tilt-r">
      <div class="split-image">
        <figure class="snapshot">
          <Image
            src={kidsZandbak}
            alt="Kinderen van verschillende leeftijden spelen samen in een zandbak op Plazey, met festivalkramen en lichtjes op de achtergrond."
            widths={[800, 1200, 1600]}
            sizes="(max-width: 767px) 100vw, 50vw"
          />
          <figcaption>De zandbak zit de hele dag vol.</figcaption>
        </figure>
      </div>
      <div class="split-text">
        <h2 id="heading-kinderen">Kinderen welkom, van baby tot tiener</h2>
        <p>Kinderen zijn van harte welkom op Plazey. Er zijn activiteiten voor de allerkleinsten tot tieners.</p>
        <dl class="kids-terms">
          <dt>Je kind kwijt?</dt>
          <dd>Kom naar de infostand. Onze medewerkers zijn herkenbaar aan hun kleurrijke t-shirt met het Plazey-logo.</dd>
          <dt>Luier?</dt>
          <dd>Luierplek op het terrein.</dd>
          <dt>Te hard geluid?</dt>
          <dd>Oordopjes en kinderkoptelefoon aan de infostand.</dd>
        </dl>
      </div>
    </section>
  </div>

  <div class="yellow-band">
    <section id="faq" aria-labelledby="heading-faq" class="faq-section">
      <Container>
        <h2 id="heading-faq">Veelgestelde vragen</h2>
        <Accordion items={faqItems} />
        <p class="faq-followup">Staat jouw vraag er niet bij? <a href="#contact" data-topic="anders">Stel je vraag.</a></p>
      </Container>
    </section>

  <aside id="contact" aria-labelledby="contact-heading" class="callout section">
    <Container>
      <div class="paper-sheet paper-sheet--beige paper-sheet--tilt-l contact-card">
      <h2 id="contact-heading">Heb je een vraag?</h2>
      <p>Over bereikbaarheid, toegankelijkheid of eten? Schrijf ons.</p>

      <div class="cta-form">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          class="flex flex-col gap-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <input type="hidden" name="origin" value="praktisch" />
          <input type="hidden" name="lang" value="nl" />

          <p class="form-note">Alle velden zijn verplicht.</p>

          <div class="form-field">
            <label for="contact-naam">Naam</label>
            <input type="text" id="contact-naam" name="naam" required />
          </div>

          <div class="form-field">
            <label for="contact-email">E-mailadres</label>
            <input type="email" id="contact-email" name="email" required />
          </div>

          <div class="form-field">
            <label for="contact-onderwerp">Onderwerp</label>
            <select id="contact-onderwerp" name="onderwerp" required>
              <option value="" disabled selected>Kies een onderwerp</option>
              <option value="bereikbaarheid">Bereikbaarheid</option>
              <option value="toegankelijkheid">Toegankelijkheid</option>
              <option value="eten">Eten &amp; drinken</option>
              <option value="kinderen">Kinderen</option>
              <option value="anders">Iets anders</option>
            </select>
          </div>

          <div class="form-field">
            <label for="contact-bericht">Bericht</label>
            <textarea id="contact-bericht" name="bericht" rows="4" required></textarea>
          </div>

          <button type="submit" class="btn-primary self-start">Stuur je bericht</button>
        </form>
      </div>
      </div>
    </Container>
  </aside>
  </div>

  <script>
    const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (!submitBtn) return;
        const originalText = submitBtn.textContent ?? '';
        submitBtn.disabled = true;
        submitBtn.textContent = 'Bezig…';
        try {
          const response = await fetch(window.location.pathname, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
          });
          if (response.ok) {
            const aside = form.closest<HTMLElement>('aside');
            if (!aside) return;
            aside.classList.add('contact-leaving');
            setTimeout(() => {
              aside.innerHTML = `<div class="max-w-4xl mx-auto px-4 sm:px-6"><div class="contact-success" role="status" tabindex="-1"><svg class="contact-success-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg><p class="contact-success-heading">Je bericht is<br>onderweg.</p></div></div>`;
              aside.classList.remove('contact-leaving');
              aside.querySelector<HTMLElement>('[role="status"]')?.focus();
            }, 280);
          } else {
            throw new Error('server error');
          }
        } catch {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
          let errorEl = form.querySelector<HTMLParagraphElement>('.form-error');
          if (!errorEl) {
            errorEl = document.createElement('p');
            errorEl.className = 'form-error';
            errorEl.setAttribute('role', 'alert');
            submitBtn.insertAdjacentElement('beforebegin', errorEl);
          }
          errorEl.textContent = '';
          errorEl.append('Er ging iets mis. Probeer het opnieuw of stuur een mail naar ');
          const mailLink = document.createElement('a');
          mailLink.href = 'mailto:info@plazey.be';
          mailLink.textContent = 'info@plazey.be';
          errorEl.append(mailLink, '.');
        }
      });
    }

  </script>

  <style is:global>
    .contact-leaving {
      opacity: 0;
      transform: scale(0.98);
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .contact-success {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 14rem;
      padding: 3rem 0;
      gap: 0.75rem;
    }

    .contact-success-icon {
      width: 2rem;
      height: 2rem;
      color: var(--color-orange);
      opacity: 0;
      animation: success-arrive 0.4s ease-out forwards;
    }

    .contact-success-heading {
      font-family: var(--font-heading);
      font-size: clamp(2.25rem, 5vw, 3.75rem);
      line-height: 1.1;
      color: var(--color-text);
      margin: 0;
      opacity: 0;
      animation: success-arrive 0.5s 0.1s ease-out forwards;
    }

    @keyframes success-arrive {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
      .contact-success-heading { animation: none; opacity: 1; }
      .contact-leaving { transition: none; opacity: 1; transform: none; }
    }
  </style>

  <script>
    const PREFILLS: Record<string, string> = {
      adl: 'Ik wil graag vragen om hulp van een vrijwilliger tijdens Plazey. Wat ik nodig heb: ',
    };

    function getOffset(): number {
      const header = document.querySelector('header') as HTMLElement | null;
      return (header?.offsetHeight ?? 0) + 8;
    }

    function scrollToId(id: string) {
      const target = document.getElementById(id);
      if (!target) return;
      const y = target.getBoundingClientRect().top + window.scrollY - getOffset();
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: y, behavior: reduced ? 'auto' : 'smooth' });
    }

    // In-page anchor pills: scroll-spy + click-to-scroll
    const sections = Array.from(document.querySelectorAll('section[id]'));
    const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.hero-anchor[href^="#"]'));
    if (sections.length && navLinks.length) {
      function update() {
        const offset = getOffset();
        let active = sections[0]?.id ?? '';
        for (const section of sections) {
          if (section.getBoundingClientRect().top <= offset + 2) active = section.id;
        }
        for (const link of navLinks) {
          if (link.getAttribute('href') === `#${active}`) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        }
      }
      for (const link of navLinks) {
        link.addEventListener('click', (e) => {
          const id = link.getAttribute('href')?.slice(1);
          if (!id) return;
          e.preventDefault();
          scrollToId(id);
          history.replaceState(null, '', `#${id}`);
        });
      }
      document.addEventListener('scroll', update, { passive: true });
      update();
    }

    // Section CTAs → contact form: preselect topic, optional message prefill
    const topicLinks = document.querySelectorAll<HTMLAnchorElement>('a[data-topic]');
    for (const link of topicLinks) {
      link.addEventListener('click', (e) => {
        const topic = link.dataset.topic;
        const prefill = link.dataset.prefill;
        if (!topic) return;
        e.preventDefault();

        const select = document.querySelector<HTMLSelectElement>('select[name="onderwerp"]');
        if (select) select.value = topic;

        const msg = document.querySelector<HTMLTextAreaElement>('textarea[name="bericht"]');
        if (msg && prefill && !msg.value) {
          msg.value = PREFILLS[prefill] ?? '';
        }

        scrollToId('contact');

        // Focus the first field so the form's H2 + all fields remain in view.
        // Focusing the message textarea (last field) would trigger the browser's
        // scroll-into-view and jump past the heading.
        setTimeout(() => {
          const naam = document.querySelector<HTMLInputElement>('input[name="naam"]');
          naam?.focus({ preventScroll: true });
        }, 500);
      });
    }
  </script>
</BaseLayout>
