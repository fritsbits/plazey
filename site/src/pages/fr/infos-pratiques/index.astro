---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Accordion from '../../../components/Accordion.astro';
import { Image } from 'astro:assets';
import { FESTIVAL_DATES_FR, FESTIVAL_LOCATION } from '../../../config/site';
import parkLaanKunst from '../../../assets/images/park-laan-kunst.jpg';
import etenFoodkraam from '../../../assets/images/eten-foodkraam.jpg';
import kidsZandbak from '../../../assets/images/kids-zandbak.jpg';
import kindOordoppen from '../../../assets/images/kind-oordoppen.jpg';

const faqItems = [
  { question: 'Plazey est-il vraiment gratuit ?', answer: "Oui. Pas de tickets, pas d'entrée payante. Plazey est gratuit pour tout le monde, depuis 1992." },
  { question: 'Puis-je apporter ma propre nourriture et boisson ?', answer: "Oui. Nourriture et boissons personnelles sont toujours les bienvenues. L'eau du robinet est gratuite au bar." },
  { question: 'Y a-t-il un vestiaire ou une consigne ?', answer: 'Non. Viens avec le moins de bagages possible.' },
  { question: 'À quelle heure commence et se termine le festival ?', answer: 'Le vendredi de 14h à minuit. Le samedi et le dimanche de 14h à 22h.' },
  { question: "Et s'il pleut ?", answer: "Plazey a toujours lieu, même sous la pluie. Le parc a des espaces couverts. Prends un imperméable par précaution." },
  { question: 'Puis-je y venir en fauteuil roulant ou avec une poussette ?', answer: 'Oui. Les allées principales sont planes et accessibles aux fauteuils roulants et poussettes. Tous les petits chemins ne le sont pas.' },
];
---

<BaseLayout title="Infos pratiques" lang="fr" currentPath="/fr/infos-pratiques">
  <section class="section hero-intro hero-green">
    <Container>
      <h1>Tout ce que tu dois savoir avant de venir.</h1>
      <p class="text-date">
        {FESTIVAL_DATES_FR}<span class="meta-sep" aria-hidden="true"></span>{FESTIVAL_LOCATION}
      </p>
      <p class="text-free"><span class="text-free-mark">Gratuit pour tout le monde.</span></p>
    </Container>
  </section>

  <div class="anchors-banner">
    <Image
      src={parkLaanKunst}
      alt=""
      widths={[960, 1440, 1920]}
      sizes="100vw"
      class="anchors-banner-img"
      loading="eager"
    />
    <Container>
      <nav class="hero-anchors" aria-label="Sur cette page">
        <a href="#acces" class="hero-anchor" style="--anchor-bg: var(--color-sage);">
          <span class="hero-anchor-num">01</span><span class="hero-anchor-label">Accès</span>
        </a>
        <a href="#manger-et-boire" class="hero-anchor" style="--anchor-bg: var(--color-yellow);">
          <span class="hero-anchor-num">02</span><span class="hero-anchor-label">Manger &amp; boire</span>
        </a>
        <a href="#accessibilite" class="hero-anchor" style="--anchor-bg: var(--color-orange);">
          <span class="hero-anchor-num">03</span><span class="hero-anchor-label">Accessibilité</span>
        </a>
        <a href="#enfants" class="hero-anchor" style="--anchor-bg: var(--color-pink);">
          <span class="hero-anchor-num">04</span><span class="hero-anchor-label">Enfants</span>
        </a>
        <a href="#questions-frequentes" class="hero-anchor hero-anchor--dark" style="--anchor-bg: var(--color-green);">
          <span class="hero-anchor-num">05</span><span class="hero-anchor-label">Questions fréquentes</span>
        </a>
      </nav>
    </Container>
  </div>

  <div>
    <Container>
      <section id="acces" aria-labelledby="heading-acces" class="page-section">
        <h2 id="heading-acces" class="h2-display">Cinq minutes à pied du <span class="underline-mustard">métro Simonis</span></h2>

        <div class="transport-grid">
          <div class="transport-card">
            <span class="mode-icon" aria-hidden="true">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="12" width="44" height="34" rx="7" fill="var(--color-orange)" stroke="var(--color-text)" stroke-width="2.5"/>
                <rect x="14" y="18" width="14" height="10" rx="2" fill="var(--color-surface)" stroke="var(--color-text)" stroke-width="2"/>
                <rect x="32" y="18" width="14" height="10" rx="2" fill="var(--color-surface)" stroke="var(--color-text)" stroke-width="2"/>
                <text x="30" y="42" text-anchor="middle" style="font-family: var(--font-heading)" font-size="14" fill="var(--color-text)">M</text>
                <circle cx="18" cy="50" r="3.5" fill="var(--color-text)"/>
                <circle cx="42" cy="50" r="3.5" fill="var(--color-text)"/>
              </svg>
            </span>
            <h3 class="mode">Métro</h3>
            <p>Ligne 2 ou 6, arrêt Simonis/Élisabeth. Cinq minutes à pied jusqu'au parc. La station a un ascenseur.</p>
          </div>

          <div class="transport-card">
            <span class="mode-icon" aria-hidden="true">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <circle cx="14" cy="42" r="11" fill="var(--color-sage)" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="46" cy="42" r="11" fill="var(--color-sage)" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="14" cy="42" r="3" fill="var(--color-text)"/>
                <circle cx="46" cy="42" r="3" fill="var(--color-text)"/>
                <path d="M14 42 L26 22 L40 42 M26 22 L42 22" stroke="var(--color-text)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="42" cy="20" r="2.5" fill="var(--color-text)"/>
              </svg>
            </span>
            <h3 class="mode">Vélo</h3>
            <p>Parking vélo non gardé sur le site. Prends un antivol.</p>
          </div>

          <div class="transport-card">
            <span class="mode-icon" aria-hidden="true">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 40 L6 30 L14 22 L46 22 L54 30 L54 40 Z" fill="var(--color-yellow)" stroke="var(--color-text)" stroke-width="2.5" stroke-linejoin="round"/>
                <path d="M14 22 L20 14 L40 14 L46 22" fill="var(--color-yellow)" stroke="var(--color-text)" stroke-width="2.5" stroke-linejoin="round"/>
                <line x1="30" y1="14" x2="30" y2="22" stroke="var(--color-text)" stroke-width="2"/>
                <circle cx="16" cy="44" r="4" fill="var(--color-text)"/>
                <circle cx="44" cy="44" r="4" fill="var(--color-text)"/>
              </svg>
            </span>
            <h3 class="mode">Voiture</h3>
            <p>Stationnement payant autour du parc, ou parking souterrain Indigoneo. Adresse : Place Eugène Simonis 24, 1081 Koekelberg.</p>
          </div>

          <div class="transport-card card-wide">
            <span class="mode-icon" aria-hidden="true">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="8" width="44" height="40" rx="6" fill="var(--color-green)" stroke="var(--color-text)" stroke-width="2.5"/>
                <rect x="13" y="14" width="14" height="9" rx="1.5" fill="var(--color-surface)" stroke="var(--color-text)" stroke-width="1.5"/>
                <rect x="33" y="14" width="14" height="9" rx="1.5" fill="var(--color-surface)" stroke="var(--color-text)" stroke-width="1.5"/>
                <rect x="13" y="27" width="34" height="6" rx="1" fill="var(--color-yellow)" stroke="var(--color-text)" stroke-width="1.5"/>
                <circle cx="18" cy="52" r="3.5" fill="var(--color-text)"/>
                <circle cx="42" cy="52" r="3.5" fill="var(--color-text)"/>
              </svg>
            </span>
            <h3 class="mode">Tram &amp; bus</h3>
            <p>Arrêt Parc Élisabeth ou Simonis/Élisabeth.</p>
            <ul>
              <li>Tram 9 ou 19</li>
              <li>Bus STIB 13, 87, N16, arrêt Parc Élisabeth</li>
              <li>Bus STIB 49 ou 53, arrêt Liberté</li>
              <li>De Lijn 212, 213, 214, 355, arrêt Parc Élisabeth</li>
            </ul>
          </div>

          <aside class="transport-help" aria-label="Besoin d'aide ?">
            <p class="transport-help-question">Besoin d'aide pour aller de la station au site ?</p>
            <a href="#contact" class="transport-help-link" data-topic="acces">Dis-le-nous <span class="arrow" aria-hidden="true">→</span></a>
          </aside>
        </div>
      </section>

      <section id="manger-et-boire" aria-labelledby="heading-manger" class="split-section split--image-right split-section--bare">
        <div class="split-image">
          <figure class="snapshot snapshot--tilt-r">
            <Image
              src={etenFoodkraam}
              alt="Un stand alimentaire sous une tente à Plazey : deux femmes préparent et servent à manger."
              widths={[600, 960, 1280]}
              sizes="(max-width: 767px) 100vw, 50vw"
            />
            <figcaption>Les stands viennent du quartier.</figcaption>
          </figure>
        </div>
        <div class="split-text eten-content">
          <h2 id="heading-manger" class="h2-display"><span class="underline-mustard">Apporte ton pique-nique,</span> ou achète au bar</h2>

          <div class="eten-menu">
            <p class="drinks-free">L'eau plate est <span>gratuite</span>.</p>
            <ul class="drinks-list">
              <li><span class="drink">Softs</span><span class="price">€ 2 à € 3</span></li>
              <li><span class="drink">Bières</span><span class="price">€ 3 à € 4</span></li>
              <li><span class="drink">Vins &amp; bulles</span><span class="price">€ 4 à € 5</span></li>
            </ul>
            <p class="drinks-note">Vins et bulles au verre. Espèces acceptées.</p>
          </div>

          <p>Nos bières viennent de brasseurs bruxellois. Il y a aussi de la bière et du mousseux sans alcool.</p>

          <p>Il y a aussi des stands alimentaires. Nous choisissons délibérément des habitant·es du quartier, des établissements horeca locaux et des start-ups. Les stands de cette année seront annoncés bientôt.</p>
        </div>
      </section>

      <section id="accessibilite" aria-labelledby="heading-accessibilite" class="page-section page-section--no-rule">
        <h2 id="heading-accessibilite" class="h2-display"><span class="underline-mustard">Tout le monde est bienvenu</span>, même si tu as besoin d'aide</h2>

        <div class="col-grid-2">
          <div class="access-cat">
            <span class="label">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="30" cy="30" r="24" fill="var(--color-orange)" stroke="var(--color-text)" stroke-width="2.5"/>
                <path d="M22 26 Q22 18 30 18 Q38 18 38 26 L38 36 Q38 42 32 42 Q28 42 28 38" stroke="var(--color-text)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M42 22 Q46 26 46 30 Q46 34 42 38" stroke="var(--color-text)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              </svg>
              Audition
            </h3>
            <ul>
              <li><strong>Bouchons d'oreilles :</strong> disponibles à l'infostand.</li>
              <li>D'autres questions sur l'audition ? <a href="#contact" data-topic="accessibilite">Pose ta question</a>, on cherche la réponse pour toi.</li>
            </ul>
          </div>

          <div class="access-cat">
            <span class="label">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="30" cy="30" r="24" fill="var(--color-sage)" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="28" cy="16" r="3" fill="var(--color-text)"/>
                <path d="M28 21 L28 33 L40 33" stroke="var(--color-text)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="32" cy="40" r="9" fill="none" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="32" cy="40" r="2" fill="var(--color-text)"/>
              </svg>
              Mobilité
            </h3>
            <ul>
              <li><strong>Allées principales planes :</strong> accessibles aux fauteuils roulants et poussettes.</li>
              <li><strong>Toilettes adaptées :</strong> pour personnes en fauteuil roulant.</li>
              <li><strong>Métro Simonis équipé d'un ascenseur :</strong> accessible en fauteuil roulant.</li>
            </ul>
          </div>

          <div class="access-cat">
            <span class="label">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="30" cy="30" r="24" fill="var(--color-yellow)" stroke="var(--color-text)" stroke-width="2.5"/>
                <circle cx="30" cy="20" r="2.5" fill="var(--color-text)"/>
                <path d="M30 27 L30 42" stroke="var(--color-text)" stroke-width="4" stroke-linecap="round"/>
              </svg>
              Aide &amp; info
            </h3>
            <ul>
              <li><strong>Aide au quotidien :</strong> des bénévoles t'aident à manger, boire, aller aux toilettes ou trouver ton chemin sur le site. <a href="#contact" data-topic="accessibilite" data-prefill="adl">Demande-le à l'avance.</a></li>
              <li><strong>Programme et liste de boissons :</strong> en braille ou en impression standard, à l'infostand.</li>
              <li><strong>Espace calme :</strong> pour se reposer du bruit.</li>
            </ul>
          </div>

          <div class="access-cat">
            <span class="label">
              <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M30 8 L48 14 L48 28 Q48 42 30 52 Q12 42 12 28 L12 14 Z" fill="var(--color-green)" stroke="var(--color-text)" stroke-width="2.5" stroke-linejoin="round"/>
                <path d="M22 30 L28 36 L40 22" stroke="var(--color-surface)" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Sécurité
            </h3>
            <ul>
              <li>Tu vois que quelqu'un est importuné ? Demande simplement : « Ça va ? »</li>
              <li>Tu ne te sens pas en sécurité ? Parle à un·e bénévole, reconnaissable à son t-shirt coloré avec le logo Plazey.</li>
              <li>On écoute sans juger et on cherche ensemble ce qu'il faut.</li>
            </ul>
          </div>
        </div>

        <figure class="snapshot snapshot--tilt-l snapshot--solo">
          <Image
            src={kindOordoppen}
            alt="Un enfant avec une protection auditive sur les épaules d'un parent, regardant un spectacle."
            widths={[520, 780]}
            sizes="(max-width: 559px) 100vw, 492px"
          />
          <figcaption>Parfois c'est trop fort. Les bouchons aident.</figcaption>
        </figure>

        <div class="callout-inline">
          <p>Une question ou besoin d'aide ? <a href="#contact" data-topic="accessibilite">Pose ta question.</a></p>
        </div>
      </section>

    </Container>

    <section id="enfants" aria-labelledby="heading-enfants" class="kids-bleed split-section split--image-left">
      <div class="split-image">
        <figure class="snapshot snapshot--tilt-r">
          <Image
            src={kidsZandbak}
            alt="Des enfants d'âges différents jouent ensemble dans un bac à sable à Plazey, avec les stands du festival et des guirlandes en arrière-plan."
            widths={[800, 1200, 1600]}
            sizes="(max-width: 767px) 100vw, 50vw"
          />
          <figcaption>Le bac à sable ne désemplit pas.</figcaption>
        </figure>
      </div>
      <div class="split-text">
        <h2 id="heading-enfants">Enfants bienvenus, du bébé à l'ado</h2>
        <p>Les enfants sont les bienvenus à Plazey. Il y a des activités pour les tout-petits jusqu'aux ados.</p>
        <dl class="kids-terms">
          <dt>Enfant perdu ?</dt>
          <dd>Viens à l'infostand. Notre équipe est reconnaissable à son t-shirt coloré avec le logo Plazey.</dd>
          <dt>Change ?</dt>
          <dd>Table à langer sur place.</dd>
          <dt>Trop fort ?</dt>
          <dd>Bouchons d'oreilles et casque enfant à l'infostand.</dd>
        </dl>
      </div>
    </section>
  </div>

  <div class="yellow-band">
    <section id="questions-frequentes" aria-labelledby="heading-faq" class="faq-section">
      <Container>
        <h2 id="heading-faq">Questions fréquentes</h2>
        <Accordion items={faqItems} />
        <p class="faq-followup">Ta question n'est pas là ? <a href="#contact" data-topic="autre">Pose ta question.</a></p>
      </Container>
    </section>

  <aside id="contact" aria-labelledby="contact-heading" class="callout section">
    <Container>
      <h2 id="contact-heading">Tu as une question ?</h2>
      <p>Accessibilité, accès, à manger ? Écris-nous.</p>

      <div class="cta-form">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          class="flex flex-col gap-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <input type="hidden" name="origin" value="infos-pratiques" />
          <input type="hidden" name="lang" value="fr" />

          <p class="form-note">Tous les champs sont obligatoires.</p>

          <div class="form-field">
            <label for="contact-naam">Nom</label>
            <input type="text" id="contact-naam" name="naam" required />
          </div>

          <div class="form-field">
            <label for="contact-email">Adresse e-mail</label>
            <input type="email" id="contact-email" name="email" required />
          </div>

          <div class="form-field">
            <label for="contact-onderwerp">Sujet</label>
            <select id="contact-onderwerp" name="onderwerp" required>
              <option value="" disabled selected>Choisis un sujet</option>
              <option value="acces">Accès</option>
              <option value="accessibilite">Accessibilité</option>
              <option value="manger">Manger &amp; boire</option>
              <option value="enfants">Enfants</option>
              <option value="autre">Autre chose</option>
            </select>
          </div>

          <div class="form-field">
            <label for="contact-bericht">Message</label>
            <textarea id="contact-bericht" name="bericht" rows="4" required></textarea>
          </div>

          <button type="submit" class="btn-primary self-start">Envoie ton message</button>
        </form>
      </div>
    </Container>
  </aside>
  </div>

  <script>
    const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (!submitBtn) return;
        const originalText = submitBtn.textContent ?? '';
        submitBtn.disabled = true;
        submitBtn.textContent = 'En cours…';
        try {
          const response = await fetch(window.location.pathname, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
          });
          if (response.ok) {
            const aside = form.closest<HTMLElement>('aside');
            if (!aside) return;
            aside.classList.add('contact-leaving');
            setTimeout(() => {
              aside.innerHTML = `<div class="max-w-4xl mx-auto px-4 sm:px-6"><div class="contact-success" role="status" tabindex="-1"><svg class="contact-success-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg><p class="contact-success-heading">Ton message est<br>en route.</p></div></div>`;
              aside.classList.remove('contact-leaving');
              aside.querySelector<HTMLElement>('[role="status"]')?.focus();
            }, 280);
          } else {
            throw new Error('server error');
          }
        } catch {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
          let errorEl = form.querySelector<HTMLParagraphElement>('.form-error');
          if (!errorEl) {
            errorEl = document.createElement('p');
            errorEl.className = 'form-error';
            errorEl.setAttribute('role', 'alert');
            submitBtn.insertAdjacentElement('beforebegin', errorEl);
          }
          errorEl.textContent = '';
          errorEl.append("Ça n'a pas marché. Réessaie ou écris-nous à ");
          const mailLink = document.createElement('a');
          mailLink.href = 'mailto:info@plazey.be';
          mailLink.textContent = 'info@plazey.be';
          errorEl.append(mailLink, '.');
        }
      });
    }

  </script>

  <style is:global>
    .contact-leaving {
      opacity: 0;
      transform: scale(0.98);
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .contact-success {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 14rem;
      padding: 3rem 0;
      gap: 0.75rem;
    }

    .contact-success-icon {
      width: 2rem;
      height: 2rem;
      color: var(--color-orange);
      opacity: 0;
      animation: success-arrive 0.4s ease-out forwards;
    }

    .contact-success-heading {
      font-family: var(--font-heading);
      font-size: clamp(2.25rem, 5vw, 3.75rem);
      line-height: 1.1;
      color: var(--color-text);
      margin: 0;
      opacity: 0;
      animation: success-arrive 0.5s 0.1s ease-out forwards;
    }

    @keyframes success-arrive {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
      .contact-success-icon,
      .contact-success-heading { animation: none; opacity: 1; }
      .contact-leaving { transition: none; opacity: 1; transform: none; }
    }
  </style>

  <script>
    const PREFILLS: Record<string, string> = {
      adl: "Je souhaiterais demander l'aide d'un·e bénévole pendant Plazey. Ce dont j'ai besoin : ",
    };

    function getOffset(): number {
      const header = document.querySelector('header') as HTMLElement | null;
      return (header?.offsetHeight ?? 0) + 8;
    }

    function scrollToId(id: string) {
      const target = document.getElementById(id);
      if (!target) return;
      const y = target.getBoundingClientRect().top + window.scrollY - getOffset();
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: y, behavior: reduced ? 'auto' : 'smooth' });
    }

    const sections = Array.from(document.querySelectorAll('section[id]'));
    const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.hero-anchor[href^="#"]'));
    if (sections.length && navLinks.length) {
      function update() {
        const offset = getOffset();
        let active = sections[0]?.id ?? '';
        for (const section of sections) {
          if (section.getBoundingClientRect().top <= offset + 2) active = section.id;
        }
        for (const link of navLinks) {
          if (link.getAttribute('href') === `#${active}`) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        }
      }
      for (const link of navLinks) {
        link.addEventListener('click', (e) => {
          const id = link.getAttribute('href')?.slice(1);
          if (!id) return;
          e.preventDefault();
          scrollToId(id);
          history.replaceState(null, '', `#${id}`);
        });
      }
      document.addEventListener('scroll', update, { passive: true });
      update();
    }

    const topicLinks = document.querySelectorAll<HTMLAnchorElement>('a[data-topic]');
    for (const link of topicLinks) {
      link.addEventListener('click', (e) => {
        const topic = link.dataset.topic;
        const prefill = link.dataset.prefill;
        if (!topic) return;
        e.preventDefault();

        const select = document.querySelector<HTMLSelectElement>('select[name="onderwerp"]');
        if (select) select.value = topic;

        const msg = document.querySelector<HTMLTextAreaElement>('textarea[name="bericht"]');
        if (msg && prefill && !msg.value) {
          msg.value = PREFILLS[prefill] ?? '';
        }

        scrollToId('contact');

        // Focus the first field so the form's H2 + all fields remain in view.
        // Focusing the message textarea (last field) would trigger the browser's
        // scroll-into-view and jump past the heading.
        setTimeout(() => {
          const naam = document.querySelector<HTMLInputElement>('input[name="naam"]');
          naam?.focus({ preventScroll: true });
        }, 500);
      });
    }
  </script>
</BaseLayout>
