---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Accordion from '../../../components/Accordion.astro';
import { Image } from 'astro:assets';
import { FESTIVAL_DATES_FR, FESTIVAL_LOCATION } from '../../../config/site';
import parkLaanKunst from '../../../assets/images/park-laan-kunst.jpg';
import etenFoodkraam from '../../../assets/images/eten-foodkraam.jpg';
import kidsZandbak from '../../../assets/images/kids-zandbak.jpg';

const faqItems = [
  { question: 'Plazey est-il vraiment gratuit ?', answer: "Oui. Pas de tickets, pas d'entrée payante. Plazey est gratuit pour tout le monde, depuis 1992." },
  { question: 'Puis-je apporter ma propre nourriture et boisson ?', answer: "Oui. Nourriture et boissons personnelles sont toujours les bienvenues. L'eau du robinet est gratuite au bar." },
  { question: 'Y a-t-il un vestiaire ou une consigne ?', answer: 'Non. Viens avec le moins de bagages possible.' },
  { question: 'À quelle heure commence et se termine le festival ?', answer: 'Le vendredi, ça commence à 19h30. On confirme les horaires du samedi et dimanche plus tard.' },
  { question: "Et s'il pleut ?", answer: "Plazey a toujours lieu, même sous la pluie. Le parc a des espaces couverts. Prends un imperméable par précaution." },
  { question: 'Puis-je y venir en fauteuil roulant ou avec une poussette ?', answer: 'Oui. Les allées principales sont planes et accessibles aux fauteuils roulants et poussettes. Tous les petits chemins ne le sont pas.' },
];
---

<BaseLayout title="Infos pratiques" lang="fr" currentPath="/fr/infos-pratiques">
  <div class="section">
    <Container>
      <h1>Infos pratiques</h1>
      <p class="text-date">{FESTIVAL_DATES_FR} · {FESTIVAL_LOCATION} · Gratuit</p>
    </Container>

    <div class="page-subnav-wrapper">
      <Container>
        <nav aria-label="Sur cette page">
          <ul role="list" class="page-nav">
            <li><a href="#acces">Accès</a></li>
            <li><a href="#manger-et-boire">Manger &amp; boire</a></li>
            <li><a href="#accessibilite">Accessibilité</a></li>
            <li><a href="#enfants">Enfants</a></li>
            <li><a href="#questions-frequentes">Questions fréquentes</a></li>
          </ul>
        </nav>
      </Container>
    </div>

    <Container>
      <section id="acces" aria-labelledby="heading-acces" class="page-section">
        <Image
          src={parkLaanKunst}
          alt="La longue allée du parc Élisabeth avec des œuvres d'art dans les arbres et des promeneurs."
          widths={[800, 1200]}
          sizes="(max-width: 768px) 100vw, 80vw"
          class="section-image"
        />
        <h2 id="heading-acces">Cinq minutes à pied du métro Simonis</h2>

        <div class="transport-grid">
          <div class="transport-card">
            <svg class="icon mode-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M2 22V12a10 10 0 1 1 20 0v10"/>
              <path d="M15 6.8v1.4a3 2.8 0 1 1-6 0V6.8"/>
              <path d="M10 15h.01"/>
              <path d="M14 15h.01"/>
              <path d="M10 19a4 4 0 0 1-4-4v-3a6 6 0 1 1 12 0v3a4 4 0 0 1-4 4Z"/>
              <path d="m9 19-2 3"/>
              <path d="m15 19 2 3"/>
            </svg>
            <span class="mode">Métro</span>
            <p>Ligne 2 ou 6, arrêt Simonis/Élisabeth. Cinq minutes à pied jusqu'au parc. La station a un ascenseur.</p>
          </div>

          <div class="transport-card">
            <svg class="icon mode-icon" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="18.5" cy="17.5" r="3.5"/>
              <circle cx="5.5" cy="17.5" r="3.5"/>
              <circle cx="15" cy="5" r="1"/>
              <path d="M12 17.5V14l-3-3 4-3 2 3h2"/>
            </svg>
            <span class="mode">Vélo</span>
            <p>Parking vélo non gardé sur le site. Prends un antivol.</p>
          </div>

          <div class="transport-card">
            <svg class="icon mode-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/>
              <circle cx="7" cy="17" r="2"/>
              <path d="M9 17h6"/>
              <circle cx="17" cy="17" r="2"/>
            </svg>
            <span class="mode">Voiture</span>
            <p>Stationnement payant autour du parc, ou parking souterrain Indigoneo. Adresse : Place Eugène Simonis 24, 1081 Koekelberg.</p>
          </div>

          <div class="transport-card card-wide">
            <svg class="icon mode-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 6v6"/>
              <path d="M15 6v6"/>
              <path d="M2 12h19.6"/>
              <path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4a2 2 0 0 0-2 2v10h3"/>
              <circle cx="7" cy="18" r="2"/>
              <path d="M9 18h5"/>
              <circle cx="16" cy="18" r="2"/>
            </svg>
            <span class="mode">Tram &amp; bus</span>
            <p>Arrêt Parc Élisabeth ou Simonis/Élisabeth.</p>
            <ul>
              <li>Tram 9 ou 19</li>
              <li>Bus STIB 13, 87, N16 — arrêt Parc Élisabeth</li>
              <li>Bus STIB 49 ou 53 — arrêt Liberté</li>
              <li>De Lijn 212, 213, 214, 355 — arrêt Parc Élisabeth</li>
            </ul>
          </div>
        </div>

        <div class="callout-inline">
          <p><strong>Besoin d'aide pour aller de la station au site ?</strong> <a href="#contact" data-topic="acces">Dis-le-nous.</a></p>
        </div>
      </section>

      <section id="manger-et-boire" aria-labelledby="heading-manger" class="page-section">
        <h2 id="heading-manger">Apporte ton pique-nique, ou achète au bar</h2>

        <div class="menu-split">
          <div>
            <h3>Au bar</h3>
            <ul class="drinks-list">
              <li><span class="drink">Eau du robinet</span><span class="dots" aria-hidden="true"></span><span class="price">gratuit</span></li>
              <li><span class="drink">Eau pétillante</span><span class="dots" aria-hidden="true"></span><span class="price">€ 1</span></li>
              <li><span class="drink">Soft</span><span class="dots" aria-hidden="true"></span><span class="price">€ 2</span></li>
              <li><span class="drink">Bière</span><span class="dots" aria-hidden="true"></span><span class="price">€ 3</span></li>
              <li><span class="drink">Vin</span><span class="dots" aria-hidden="true"></span><span class="price">€ 4</span></li>
              <li><span class="drink">Café</span><span class="dots" aria-hidden="true"></span><span class="price" data-pending="true">à confirmer</span></li>
            </ul>
          </div>
          <Image
            src={etenFoodkraam}
            alt="Un stand alimentaire sous une tente à Plazey : deux femmes préparent et servent à manger."
            widths={[400, 800]}
            sizes="(max-width: 640px) 100vw, 50vw"
          />
        </div>

        <p>Il y a aussi des stands alimentaires. Nous choisissons délibérément des habitant·es du quartier, des établissements horeca locaux et des start-ups. Les stands de cette année seront annoncés bientôt.</p>

        <p>Espèces acceptées.</p>
      </section>

      <section id="accessibilite" aria-labelledby="heading-accessibilite" class="page-section">
        <h2 id="heading-accessibilite">Tout le monde est bienvenu, même si tu as besoin d'aide</h2>

        <div class="col-grid-2">
          <div class="access-cat">
            <span class="label">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z"/></svg>
              Audition
            </span>
            <ul>
              <li><strong>Appareil CM1</strong> — à l'infostand. Connexion directe avec la sonorisation.</li>
              <li><strong>Interprète LSFB</strong> — dimanche de 15h à 19h.</li>
              <li><strong>Bouchons d'oreilles</strong> — disponibles à l'infostand.</li>
            </ul>
          </div>

          <div class="access-cat">
            <span class="label">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="16" cy="4" r="1"/><path d="m18 19 1-7-6 1"/><path d="m5 8 3-3 5.5 3-2.36 3.5"/><path d="M4.24 14.5a5 5 0 0 0 6.88 6"/><path d="M13.76 17.5a5 5 0 0 0-6.88-6"/></svg>
              Mobilité
            </span>
            <ul>
              <li><strong>Allées principales planes</strong> — accessibles aux fauteuils roulants et poussettes.</li>
              <li><strong>Toilettes adaptées</strong> — pour personnes en fauteuil roulant.</li>
              <li><strong>Métro Simonis équipé d'un ascenseur</strong> — accessible en fauteuil roulant.</li>
            </ul>
          </div>

          <div class="access-cat">
            <span class="label">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"/></svg>
              Aide &amp; info
            </span>
            <ul>
              <li><strong>Aide au quotidien</strong> — des bénévoles t'aident à manger, boire, aller aux toilettes ou trouver ton chemin sur le site. <a href="#contact" data-topic="accessibilite" data-prefill="adl">Demande-le à l'avance.</a></li>
              <li><strong>Programme et liste de boissons en braille</strong> — et en impression standard — à l'infostand.</li>
              <li><strong>Espace calme</strong> — pour se reposer du bruit.</li>
            </ul>
          </div>

          <div class="access-cat">
            <span class="label">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
              Sécurité
            </span>
            <ul>
              <li>Tu vois que quelqu'un est importuné ? Demande simplement : « Ça va ? »</li>
              <li>Tu ne te sens pas en sécurité ? Parle à un·e bénévole — t-shirt jaune ou rose.</li>
              <li>On écoute sans juger et on cherche ensemble ce qu'il faut.</li>
            </ul>
          </div>
        </div>

        <div class="callout-inline">
          <p>Une question ou besoin d'aide ? <a href="#contact" data-topic="accessibilite">Pose ta question.</a></p>
        </div>
      </section>

      <section id="enfants" aria-labelledby="heading-enfants" class="page-section">
        <h2 id="heading-enfants">Enfants bienvenus, du bébé à l'ado</h2>
        <div class="kids-split">
          <Image
            src={kidsZandbak}
            alt="Des enfants d'âges différents jouent ensemble dans un bac à sable à Plazey, avec les stands du festival et des guirlandes en arrière-plan."
            widths={[400, 800]}
            sizes="(max-width: 640px) 100vw, 50vw"
          />
          <div>
            <p>Les enfants sont les bienvenus à Plazey. Il y a des activités pour les tout-petits jusqu'aux ados.</p>
            <dl class="kids-terms">
              <dt>Enfant perdu ?</dt>
              <dd>Viens à l'infostand.</dd>
              <dt>Change ?</dt>
              <dd>Table à langer sur place.</dd>
              <dt>Trop fort ?</dt>
              <dd>Bouchons d'oreilles et casque enfant à l'infostand.</dd>
            </dl>
          </div>
        </div>
      </section>

      <section id="questions-frequentes" aria-labelledby="heading-faq" class="page-section">
        <h2 id="heading-faq">Questions fréquentes</h2>
        <Accordion items={faqItems} />
        <p>Ta question n'est pas là ? <a href="#contact" data-topic="autre">Pose ta question.</a></p>
      </section>
    </Container>
  </div>

  <aside id="contact" aria-labelledby="contact-heading" class="callout section">
    <Container>
      <h2 id="contact-heading">Tu as une question ?</h2>
      <p>Accessibilité, accès, à manger — écris-nous.</p>

      <div class="cta-form">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          class="flex flex-col gap-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <input type="hidden" name="origin" value="infos-pratiques" />
          <input type="hidden" name="lang" value="fr" />

          <div class="form-field">
            <label for="contact-naam">Nom</label>
            <input type="text" id="contact-naam" name="naam" required />
          </div>

          <div class="form-field">
            <label for="contact-email">Adresse e-mail</label>
            <input type="email" id="contact-email" name="email" required />
          </div>

          <div class="form-field">
            <label for="contact-onderwerp">Sujet</label>
            <select id="contact-onderwerp" name="onderwerp" required>
              <option value="" disabled selected>Choisis un sujet</option>
              <option value="acces">Accès</option>
              <option value="accessibilite">Accessibilité</option>
              <option value="manger">Manger &amp; boire</option>
              <option value="enfants">Enfants</option>
              <option value="autre">Autre chose</option>
            </select>
          </div>

          <div class="form-field">
            <label for="contact-bericht">Message</label>
            <textarea id="contact-bericht" name="bericht" rows="4" required></textarea>
          </div>

          <button type="submit" class="btn-primary self-start">Envoie ton message</button>
        </form>
      </div>
    </Container>
  </aside>

  <script>
    const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (!submitBtn) return;
        const originalText = submitBtn.textContent ?? '';
        submitBtn.disabled = true;
        submitBtn.textContent = 'En cours…';
        try {
          const response = await fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
          });
          if (response.ok) {
            form.innerHTML = '<p class="py-4 font-semibold">Merci ! On te répond dès que possible.</p>';
          } else {
            throw new Error('server error');
          }
        } catch {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
          let errorEl = form.querySelector<HTMLParagraphElement>('.form-error');
          if (!errorEl) {
            errorEl = document.createElement('p');
            errorEl.className = 'form-error';
            submitBtn.insertAdjacentElement('beforebegin', errorEl);
          }
          errorEl.textContent = 'Quelque chose a mal tourné. Réessaie ou envoie un mail à info@plazey.be.';
        }
      });
    }
  </script>

  <script>
    const PREFILLS: Record<string, string> = {
      adl: "Je souhaiterais demander l'aide d'un·e bénévole pendant Plazey. Ce dont j'ai besoin : ",
    };

    function getOffset(): number {
      const header = document.querySelector('header') as HTMLElement | null;
      const subnav = document.querySelector('.page-subnav-wrapper') as HTMLElement | null;
      const headerH = header?.offsetHeight ?? 0;
      const subnavSticky = subnav ? getComputedStyle(subnav).position === 'sticky' : false;
      const subnavH = subnavSticky ? (subnav?.offsetHeight ?? 0) : 0;
      return headerH + subnavH + 8;
    }

    function scrollToId(id: string) {
      const target = document.getElementById(id);
      if (!target) return;
      const y = target.getBoundingClientRect().top + window.scrollY - getOffset();
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: y, behavior: reduced ? 'auto' : 'smooth' });
    }

    const sections = Array.from(document.querySelectorAll('section[id]'));
    const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.page-nav a[href^="#"]'));
    if (sections.length && navLinks.length) {
      function update() {
        const offset = getOffset();
        let active = sections[0]?.id ?? '';
        for (const section of sections) {
          if (section.getBoundingClientRect().top <= offset) active = section.id;
        }
        for (const link of navLinks) {
          if (link.getAttribute('href') === `#${active}`) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        }
      }
      for (const link of navLinks) {
        link.addEventListener('click', (e) => {
          const id = link.getAttribute('href')?.slice(1);
          if (!id) return;
          e.preventDefault();
          scrollToId(id);
          history.replaceState(null, '', `#${id}`);
        });
      }
      document.addEventListener('scroll', update, { passive: true });
      update();
    }

    const topicLinks = document.querySelectorAll<HTMLAnchorElement>('a[data-topic]');
    for (const link of topicLinks) {
      link.addEventListener('click', (e) => {
        const topic = link.dataset.topic;
        const prefill = link.dataset.prefill;
        if (!topic) return;
        e.preventDefault();

        const select = document.querySelector<HTMLSelectElement>('select[name="onderwerp"]');
        if (select) select.value = topic;

        const msg = document.querySelector<HTMLTextAreaElement>('textarea[name="bericht"]');
        if (msg && prefill && !msg.value) {
          msg.value = PREFILLS[prefill] ?? '';
        }

        scrollToId('contact');

        // Focus the first field so the form's H2 + all fields remain in view.
        // Focusing the message textarea (last field) would trigger the browser's
        // scroll-into-view and jump past the heading.
        setTimeout(() => {
          const naam = document.querySelector<HTMLInputElement>('input[name="naam"]');
          naam?.focus({ preventScroll: true });
        }, 500);
      });
    }
  </script>
</BaseLayout>
