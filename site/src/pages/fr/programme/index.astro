---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import ProgramCard from '../../../components/ProgramCard.astro';
import { getCollection, render } from 'astro:content';
import { SITE_PHASE, SHOW_ACT_TIMES, FACEBOOK_URL } from '../../../config/site.ts';

const allItems = await getCollection('programme');
const items = allItems
  .filter(e => e.id.startsWith('fr/') && !e.data.draft)
  .sort((a, b) => {
    const dayOrder: Record<string, number> = { friday: 0, saturday: 1, sunday: 2 };
    const dayDiff = (dayOrder[a.data.day] ?? 0) - (dayOrder[b.data.day] ?? 0);
    if (dayDiff !== 0) return dayDiff;
    return a.data.startTime.localeCompare(b.data.startTime);
  });

// Le corps markdown se déplie dans la carte. Les items sans corps (et sans
// embed/artiste) restent des cartes statiques : aucun clic sans suite.
const withContent = await Promise.all(
  items.map(async item => ({
    item,
    Content: item.body?.trim() ? (await render(item)).Content : null,
  }))
);

// On n'affiche que les puces de type qui ont vraiment des items. Combiné au
// choix unique, un résultat vide devient impossible : pas d'état vide à gérer.
// L'ordre suit ces listes.
const presentDays = new Set<string>(items.map(e => e.data.day));
const presentTypes = new Set<string>(items.map(e => e.data.type));

const days = [
  { value: 'friday', label: 'Vendredi 28 août', weekday: 'Vendredi', date: '28 août' },
  { value: 'saturday', label: 'Samedi 29 août', weekday: 'Samedi', date: '29 août' },
  { value: 'sunday', label: 'Dimanche 30 août', weekday: 'Dimanche', date: '30 août' },
].filter(d => presentDays.has(d.value));

const types = [
  { value: 'concert', label: 'Concert' },
  { value: 'dans', label: 'Danse' },
  { value: 'film', label: 'Film' },
  { value: 'workshop', label: 'Atelier' },
  { value: 'kids', label: 'Enfants' },
  { value: 'expo', label: 'Expo' },
  { value: 'theater', label: 'Théâtre' },
  { value: 'kermis', label: 'Fête foraine' },
  { value: 'off-stage', label: 'Hors scène' },
].filter(t => presentTypes.has(t.value));
---

<BaseLayout title="Programme" lang="fr" currentPath="/fr/programme" bodyClass="page-programme">
  <img src="/decor/basiliek.png" alt="" aria-hidden="true" class="programme-basiliek" width="1047" height="844" />
  <img src="/decor/trees-lamps.png" alt="" aria-hidden="true" class="programme-trees" width="1166" height="1554" />
  <section class="section hero-intro section--green">
    <Container>
      <div class="programme-title-row">
        <h1>Programme</h1>
        {SITE_PHASE !== 'save-the-date' && days.length > 1 && (
          <nav class="day-jump" aria-label="Aller à un jour">
            {days.map(d => (
              <a href={`#day-${d.value}`} data-day={d.value}>{d.weekday}</a>
            ))}
          </nav>
        )}
      </div>

      {SITE_PHASE === 'save-the-date' ? (
        <>
          <p class="opening">Le programme 2026 arrive bientôt.</p>
          <p><a href={FACEBOOK_URL} rel="external noopener" target="_blank">Suis-nous sur Facebook pour l'annonce.</a></p>
        </>
      ) : (
        <>
          <p class="opening">28–30 août 2026. Tout est gratuit.</p>
          {!SHOW_ACT_TIMES && <p class="text-meta">Les horaires détaillés par acte suivront bientôt.</p>}

          {SITE_PHASE === 'aftermovie' && (
            <div role="note" class="season-banner my-4 p-4 image-rounded" style="background: var(--color-surface-muted);">
              <p>C'était le programme de Plazey 2026.</p>
            </div>
          )}

      <div class="filter-section">
        <div id="type-filter" class="programme-filter" role="group" aria-label="Filtrer par type" hidden>
          {types.map(t => (
            <button type="button" class="filter-pill" data-type={t.value} aria-pressed="false">{t.label}</button>
          ))}
        </div>
      </div>

      <div role="status" aria-live="polite" aria-atomic="true" id="filter-status" class="sr-only"></div>

      <div id="programme-list">
        {days.map(day => {
          const dayItems = withContent.filter(({ item }) => item.data.day === day.value);
          if (dayItems.length === 0) return null;
          return (
            <section data-day={day.value} aria-labelledby={`day-${day.value}`}>
              <h2 id={`day-${day.value}`} class="day-header">
                <span class="day-header-weekday">{day.weekday}</span> <span class="day-header-date">{day.date}</span>
              </h2>
              <ul role="list" class="program-cards columns-1 sm:columns-2 lg:columns-3 gap-4">
                {dayItems.map(({ item, Content }) => {
                  const cardProps = {
                    title: item.data.title,
                    startTime: item.data.startTime,
                    type: item.data.type,
                    dayLabel: day.label,
                    lang: 'fr' as const,
                    ...(item.data.stage && { stage: item.data.stage }),
                    ...(item.data.endTime && { endTime: item.data.endTime }),
                    ...(item.data.curator && { curator: item.data.curator }),
                    ...(item.data.genre && { subtitle: item.data.genre }),
                    ...(item.data.description && { description: item.data.description }),
                    ...(item.data.artist && { artist: item.data.artist }),
                    ...(item.data.embedUrl && { embedUrl: item.data.embedUrl }),
                  };
                  return (
                    <li class="mb-4 break-inside-avoid" data-type={item.data.type} data-day={item.data.day}>
                      {Content ? (
                        <ProgramCard {...cardProps}><Content /></ProgramCard>
                      ) : (
                        <ProgramCard {...cardProps} />
                      )}
                    </li>
                  );
                })}
              </ul>
            </section>
          );
        })}
      </div>

        </>
      )}
    </Container>

    <div class="programme-illustrations" aria-hidden="true">
      <img src="/decor/basiliek.png" alt="" width="1047" height="844" />
      <img src="/decor/trees-lamps.png" alt="" width="1166" height="1554" />
    </div>
  </section>
</BaseLayout>

<script>
  // Un seul axe de filtrage : le type. Les jours sont la structure de la page
  // (titres + liens d'ancrage), pas un état — on les voit déjà en défilant.
  const bar = document.getElementById('type-filter');
  const status = document.getElementById('filter-status');
  const list = document.getElementById('programme-list');
  const jump = document.querySelector<HTMLElement>('.day-jump');

  // Le programme (et tout ce bloc) est absent en phase save-the-date.
  if (bar && status && list) {
    // Les puces ne font rien sans JS : on ne les affiche qu'une fois le script actif.
    bar.hidden = false;

    const chips = Array.from(bar.querySelectorAll<HTMLButtonElement>('button[data-type]'));
    let active: string | null = null;

    // `announce` reste false au premier rendu : la zone live ne doit pas
    // annoncer un décompte que personne n'a demandé.
    function apply(announce: boolean) {
      let visible = 0;
      list!.querySelectorAll<HTMLElement>('li[data-type]').forEach(card => {
        const show = !active || card.dataset.type === active;
        card.hidden = !show;
        if (show) visible++;
      });

      // On masque le titre d'un jour, et son lien d'ancrage, quand aucune de ses
      // cartes ne passe le filtre. On cible section[data-day] : les cartes
      // portent aussi data-day, donc un simple [data-day] les masquerait à tort.
      list!.querySelectorAll<HTMLElement>('section[data-day]').forEach(section => {
        const empty = !section.querySelector('li[data-type]:not([hidden])');
        section.hidden = empty;
        const link = jump?.querySelector<HTMLElement>(`a[data-day="${section.dataset.day}"]`);
        if (link) link.hidden = empty;
      });

      chips.forEach(c => c.setAttribute('aria-pressed', String(c.dataset.type === active)));

      if (announce) {
        status!.textContent = `${visible} résultat${visible > 1 ? 's' : ''}.`;
      }

      const url = new URL(window.location.href);
      if (active) url.searchParams.set('type', active); else url.searchParams.delete('type');
      window.history.replaceState({}, '', url.toString());
    }

    bar.addEventListener('click', e => {
      const chip = (e.target as HTMLElement).closest<HTMLButtonElement>('button[data-type]');
      if (!chip) return;
      // Recliquer sur la puce active la désactive : on revient à tout afficher.
      active = active === chip.dataset.type ? null : chip.dataset.type!;
      apply(true);
    });

    const fromURL = new URLSearchParams(window.location.search).get('type');
    if (fromURL && chips.some(c => c.dataset.type === fromURL)) active = fromURL;
    apply(false);
  }
</script>
