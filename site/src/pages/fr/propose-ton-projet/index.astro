---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Accordion from '../../../components/Accordion.astro';
import { Image } from 'astro:assets';
import concertRapBasiliek from '../../../assets/images/concert-rap-basiliek.jpg';
import parkLaanKunst from '../../../assets/images/park-laan-kunst.jpg';
import dansPark from '../../../assets/images/dans-park.jpg';
import muziekTromClose from '../../../assets/images/muziek-trom-close.jpg';

const exemples = [
  {
    src: concertRapBasiliek,
    alt: 'Deux MC sur une scène en plein air devant un public dense, la Basilique de Koekelberg en arrière-plan.',
    titre: 'Les groupes du quartier sur scène',
    texte: 'Club 1030 a programmé quatre jeunes groupes du quartier.',
    type: 'Musique',
    typeColor: 'coral',
    format: 'Grande scène',
  },
  {
    src: parkLaanKunst,
    alt: 'Allée d\'arbres du Parc Elisabeth avec des œuvres d\'art accrochées aux branches, des visiteurs marchent en dessous.',
    titre: 'De l\'art dans les arbres',
    texte: 'Arborescences a donné un arbre du parc à chaque artiste.',
    type: 'Art',
    typeColor: 'blush',
    format: 'Dans le parc',
  },
  {
    src: dansPark,
    alt: 'Groupe de personnes de différents âges dansant ensemble entre les arbres du parc.',
    titre: 'Danser ensemble',
    texte: 'Etage Tropical a donné des ateliers ouverts à toutes et tous.',
    type: 'Danse',
    typeColor: 'mustard',
    format: 'Atelier',
  },
  {
    src: muziekTromClose,
    alt: 'Gros plan d\'une grosse caisse frappée par un maillet, un trompettiste derrière.',
    titre: 'Les percussions du quartier',
    texte: 'Fanfakids a traversé le parc avec tambours et trompettes.',
    type: 'Musique',
    typeColor: 'coral',
    format: 'À travers le parc',
  },
];

const faqItems = [
  { question: 'Je n\'ai pas d\'association. Est-ce que je peux quand même proposer quelque chose ?', answer: 'Oui. Les individus sont bienvenu·es.' },
  { question: 'Je dois parler néerlandais ou français ?', answer: 'Non. Plazey est multilingue. Propose dans la langue qui te convient.' },
  { question: 'Est-ce que je suis payé·e ?', answer: 'On travaille avec un budget limité. Indique dans ta proposition ce dont tu as besoin. On te répond honnêtement sur ce qu\'on peut couvrir ou non.' },
  { question: 'Jusqu\'à quand je peux proposer ?', answer: 'On planifie le programme en hiver. Plus tu proposes tôt, plus tu as de chances.' },
  { question: 'Il y a une limite sur ce qui est possible ?', answer: 'Presque pas. Musique, danse, théâtre, cinéma, atelier, cuisine, sport, art, enfants. Envoie et on en parle.' },
  { question: 'Qu\'est-ce qui se passe avec ma proposition ?', answer: 'On lit chaque proposition et on te recontacte. Parfois on propose une rencontre. Parfois on adapte ton idée ensemble.' },
];
---

<BaseLayout title="Proposer un projet" lang="fr" currentPath="/fr/propose-ton-projet">
  <section class="section hero-intro hero-green">
    <Container>
      <h1>Proposer un projet</h1>
      <p class="opening">Plazey, c'est le quartier qui le fait. Des habitant·es, des artistes locaux et de petites associations mettent chaque année une partie du programme sur pied. Peut-être toi aussi.</p>
      <div class="cta-group">
        <a href="#envoi" class="btn-primary">Propose ton projet</a>
      </div>
    </Container>
  </section>

  <section aria-labelledby="exemples-heading" class="section">
    <Container>
      <h2 id="exemples-heading">Qu'ont déjà fait les habitant·es ?</h2>

      <ul role="list" class="exemple-list">
        {exemples.map((e) => (
          <li class="exemple-row">
            <Image
              src={e.src}
              alt={e.alt}
              widths={[120, 220]}
              sizes="88px"
              class="exemple-thumb"
            />
            <div class="exemple-body">
              <ul class="chip-row" aria-label="Type de projet">
                <li class={`chip chip-${e.typeColor}`}>{e.type}</li>
                <li class="chip chip-neutral">{e.format}</li>
              </ul>
              <h3>{e.titre}</h3>
              <p>{e.texte}</p>
            </div>
          </li>
        ))}
      </ul>

      <p class="mt-6">Aussi vu à Plazey : des balades dans Koekelberg, un club de lecture pour enfants, un labo de théâtre inclusif, une chorale ouverte à tout le monde, des films de cinéastes bruxellois·es, un apéro littéraire.</p>
      <p>Tu vois : musique, danse, théâtre, cinéma, lecture, cuisine, sport. Petit ou grand. Pour un après-midi ou pour trois jours.</p>

      <div class="proposal-bridge">
        <h2>Et ton idée ?</h2>
        <p>On t'écoute volontiers.</p>
        <a href="#envoi" class="btn-primary">Propose ton projet</a>
      </div>
    </Container>
  </section>

  <div class="yellow-band">
  <section aria-labelledby="questions-proposition" class="faq-section">
    <Container>
      <h2 id="questions-proposition">Questions</h2>
      <Accordion items={faqItems} />
    </Container>
  </section>

  <aside id="envoi" aria-labelledby="envoi-heading" class="callout section">
    <Container>
      <h2 id="envoi-heading" class="h2-display">Propose ton <span class="underline-mustard">projet</span>.</h2>
      <p>On lit chaque proposition et on te recontacte.</p>

      <div class="cta-form">
        <form
          name="proposition-projet"
          method="POST"
          data-netlify="true"
          class="flex flex-col gap-6"
        >
            <input type="hidden" name="form-name" value="proposition-projet" />

            <p class="form-note">Tous les champs sont obligatoires, sauf mention (facultatif).</p>

            <div class="form-field">
              <label for="naam-pv">Nom</label>
              <input
                type="text"
                id="naam-pv"
                name="naam"
                required
                autocomplete="name"
                maxlength="200"
              />
            </div>

            <div class="form-field">
              <label for="email-pv">Adresse e-mail</label>
              <input
                type="email"
                id="email-pv"
                name="email"
                required
                autocomplete="email"
                maxlength="254"
              />
            </div>

            <div class="form-field">
              <label for="project-omschrijving">C'est quoi ton idée ?</label>
              <textarea
                id="project-omschrijving"
                name="omschrijving"
                rows="4"
                required
                maxlength="2000"
              ></textarea>
            </div>

            <div class="form-field">
              <label for="project-nodig">De quoi as-tu besoin ? <span style="font-weight: 400; color: var(--color-text-muted)">(espace, matériel, temps)</span> <small class="field-optional">(facultatif)</small></label>
              <textarea
                id="project-nodig"
                name="nodig"
                rows="3"
                maxlength="1000"
              ></textarea>
            </div>

            <fieldset class="flex flex-col gap-2">
              <legend class="font-semibold text-sm">Pour quel jour tu penses ? <small class="field-optional">(facultatif)</small></legend>
              <label class="flex items-center gap-2"><input type="radio" name="dag" value="vrijdag" /> Vendredi</label>
              <label class="flex items-center gap-2"><input type="radio" name="dag" value="zaterdag" /> Samedi</label>
              <label class="flex items-center gap-2"><input type="radio" name="dag" value="zondag" /> Dimanche</label>
              <label class="flex items-center gap-2"><input type="radio" name="dag" value="weet-nog-niet" /> Je ne sais pas encore</label>
            </fieldset>

            <p class="text-sm" style="color: var(--color-text-muted)">Pas encore tout au point ? Pas grave. Envoie ce que tu as, on réfléchit avec toi.</p>
            <button type="submit" class="btn-primary self-start">Envoie ma proposition</button>
          </form>
      </div>
    </Container>
  </aside>
  </div>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('form[name="proposition-projet"]');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!submitBtn) return;
      const originalText = submitBtn.textContent ?? '';
      submitBtn.disabled = true;
      submitBtn.textContent = 'En cours…';
      try {
        const response = await fetch(window.location.pathname, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
        });
        if (response.ok) {
          const aside = form.closest<HTMLElement>('aside');
          if (!aside) return;
          aside.classList.add('contact-leaving');
          setTimeout(() => {
            aside.innerHTML = `<div class="max-w-4xl mx-auto px-4 sm:px-6"><div class="contact-success" role="status" tabindex="-1"><svg class="contact-success-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg><p class="contact-success-heading">Ta proposition<br>est en route.</p></div></div>`;
            aside.classList.remove('contact-leaving');
            aside.querySelector<HTMLElement>('[role="status"]')?.focus();
          }, 280);
        } else {
          throw new Error('server error');
        }
      } catch {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        let errorEl = form.querySelector<HTMLParagraphElement>('.form-error');
        if (!errorEl) {
          errorEl = document.createElement('p');
          errorEl.className = 'form-error';
          errorEl.setAttribute('role', 'alert');
          submitBtn.insertAdjacentElement('beforebegin', errorEl);
        }
        errorEl.textContent = '';
        errorEl.append("Ça n'a pas marché. Réessaie ou écris-nous à ");
        const mailLink = document.createElement('a');
        mailLink.href = 'mailto:info@plazey.be';
        mailLink.textContent = 'info@plazey.be';
        errorEl.append(mailLink, '.');
      }
    });
  }
</script>

<style is:global>
  .contact-leaving {
    opacity: 0;
    transform: scale(0.98);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .contact-success {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 14rem;
    padding: 3rem 0;
    gap: 0.75rem;
  }

  .contact-success-icon {
    width: 2rem;
    height: 2rem;
    color: var(--color-orange);
    opacity: 0;
    animation: success-arrive 0.4s ease-out forwards;
  }

  .contact-success-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.1;
    color: var(--color-text);
    margin: 0;
    opacity: 0;
    animation: success-arrive 0.5s 0.1s ease-out forwards;
  }

  @keyframes success-arrive {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-success-icon,
    .contact-success-heading { animation: none; opacity: 1; }
    .contact-leaving { transition: none; opacity: 1; transform: none; }
  }
</style>
