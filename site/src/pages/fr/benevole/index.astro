---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Accordion from '../../../components/Accordion.astro';
import { Image } from 'astro:assets';
import vrijwilligersBar from '../../../assets/images/vrijwilligers-bar.jpg';
import etenGrillen from '../../../assets/images/eten-grillen.jpg';

const faqItems = [
  { question: "Dois-je m'inscrire pour aider ?", answer: 'Oui, remplis le formulaire. On te répond dès que possible.' },
  { question: 'Est-ce que je reçois à manger et à boire ?', answer: "Oui. Plazey t'offre un repas et des boissons pendant que tu aides." },
  { question: 'Puis-je venir seulement une demi-journée ?', answer: "Oui, c'est possible. Indique-le dans le formulaire." },
  { question: "Puis-je venir avec des ami·es ?", answer: "Oui, avec plaisir. Indique-le dans le formulaire." },
  { question: 'Je ne parle ni néerlandais ni français. Puis-je quand même aider ?', answer: 'Oui. Plazey est multilingue. Indique quelles langues tu parles.' },
];
---

<BaseLayout title="Venir aider" lang="fr" currentPath="/fr/benevole" bodyClass="page-orange">
  <section class="section hero-intro hero-green">
    <Container>
      <h1>Venir aider</h1>
      <p class="opening">Derrière le bar, à la caisse, ou pour le rangement. Chaque année, plus de cent personnes rendent Plazey possible.</p>
      <div class="cta-group">
        <a href="#inscription" class="btn-primary">Deviens bénévole</a>
      </div>
    </Container>
  </section>

  <section aria-labelledby="devenir-benevole" class="section">
    <Container>
      <h2 id="devenir-benevole">Devenir bénévole</h2>
      <p>Plazey tourne grâce à ses bénévoles. Chaque année, plus de cent personnes rendent le festival possible. Tu peux en faire partie.</p>
      <p>Tu choisis combien de temps tu veux aider : une demi-journée, une journée entière ou tout le week-end.</p>

      <ul role="list" class="roles-list">
        <li>
          <h3>Bar</h3>
          <p>Tu sers les boissons et t'assures que tout le monde a ce qu'il lui faut. Tu travailles en équipe. Pas besoin d'expérience.</p>
        </li>
        <li>
          <h3>Caisse</h3>
          <p>Les visiteur·euses achètent ici leurs tokens. Tu es le premier contact pour celles et ceux qui entrent sur le site. Parler plusieurs langues est un plus.</p>
        </li>
        <li>
          <h3>Infostand</h3>
          <p>Tu réponds aux questions, distribues les programmes et aides les gens à s'orienter. Parler plusieurs langues est un atout.</p>
        </li>
        <li>
          <h3>Rangement et montage</h3>
          <p>Avant ou après le festival, tu aides à installer le site ou à le remettre en ordre. Travail concret et pratique.</p>
        </li>
      </ul>

      <div class="image-pair">
        <Image
          src={vrijwilligersBar}
          alt="Des bénévoles en t-shirt rose Plazey derrière le bar."
          widths={[400, 600]}
          sizes="(max-width: 640px) 100vw, 50vw"
          class="sticker-img sticker-img--yellow"
        />
        <Image
          src={etenGrillen}
          alt="Un·e bénévole en t-shirt Plazey grille des brochettes à un stand extérieur."
          widths={[400, 600]}
          sizes="(max-width: 640px) 100vw, 50vw"
          class="sticker-img sticker-img--sage"
        />
      </div>

      <p>Tu n'as pas besoin d'expérience. Plazey t'offre un repas et des boissons pendant que tu aides.</p>
    </Container>
  </section>

  <div class="yellow-band">
  <section aria-labelledby="questions-benevoles" class="faq-section">
    <Container>
      <h2 id="questions-benevoles">Questions</h2>
      <Accordion items={faqItems} />
    </Container>
  </section>

  <aside id="inscription" aria-labelledby="inscription-heading" class="callout section">
    <Container>
      <h2 id="inscription-heading">Deviens bénévole.</h2>
      <p>Envoie-nous tes coordonnées. On te répond dès que possible.</p>

      <div class="cta-form">
        <form
          name="benevole"
          method="POST"
          data-netlify="true"
          class="flex flex-col gap-5"
        >
            <input type="hidden" name="form-name" value="benevole" />

            <p class="form-note">Tous les champs sont obligatoires, sauf mention (facultatif).</p>

            <div class="form-field form-field--narrow">
              <label for="naam-vw">Nom</label>
              <input
                type="text"
                id="naam-vw"
                name="naam"
                required
                autocomplete="name"
                maxlength="200"
              />
            </div>

            <div class="form-field form-field--narrow">
              <label for="email-vw">Adresse e-mail</label>
              <input
                type="email"
                id="email-vw"
                name="email"
                required
                autocomplete="email"
                maxlength="254"
              />
            </div>

            <fieldset class="option-group">
              <legend>Quand es-tu disponible ? <small class="field-optional">(facultatif)</small></legend>
              <div class="options">
                <label><input type="checkbox" name="beschikbaarheid" value="vrijdag" /> Vendredi</label>
                <label><input type="checkbox" name="beschikbaarheid" value="zaterdag" /> Samedi</label>
                <label><input type="checkbox" name="beschikbaarheid" value="zondag" /> Dimanche</label>
              </div>
            </fieldset>

            <fieldset class="option-group">
              <legend>Qu'est-ce qui t'intéresse ? <small class="field-optional">(facultatif)</small></legend>
              <div class="options">
                <label><input type="checkbox" name="rol" value="bar" /> Bar</label>
                <label><input type="checkbox" name="rol" value="kassa" /> Caisse</label>
                <label><input type="checkbox" name="rol" value="infostand" /> Infostand</label>
                <label><input type="checkbox" name="rol" value="opbouw-opruim" /> Rangement et montage</label>
              </div>
            </fieldset>

            <div class="form-field">
              <label for="talen-vw">Quelles langues parles-tu ? <small class="field-optional">(facultatif)</small></label>
              <input
                type="text"
                id="talen-vw"
                name="talen"
                placeholder="ex. néerlandais, français, anglais"
                maxlength="200"
                autocomplete="language"
              />
            </div>

            <div class="form-field">
              <label for="extra-vw">Autre chose ? <small class="field-optional">(facultatif)</small></label>
              <textarea
                id="extra-vw"
                name="extra"
                rows="3"
                maxlength="1000"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary self-start">Inscris-moi</button>
          </form>
      </div>
    </Container>
  </aside>
  </div>
</BaseLayout>

<style>
  .roles-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem;
    margin: 1.5rem 0;
  }
  @media (max-width: 639px) {
    .roles-list { grid-template-columns: 1fr; gap: 1.25rem; }
  }
  .roles-list li {
    background: var(--color-surface-muted);
    border: 2.5px solid var(--color-text);
    border-radius: 1.5rem;
    padding: 1.5rem 1.5rem;
    box-shadow: 6px 6px 0 var(--color-shadow-ink);
    margin: 0;
  }
  .roles-list li:nth-child(4n+1) { transform: rotate(-0.6deg); }
  .roles-list li:nth-child(4n+2) { transform: rotate(0.4deg); }
  .roles-list li:nth-child(4n+3) { transform: rotate(-0.3deg); }
  .roles-list li:nth-child(4n+4) { transform: rotate(0.5deg); }
  .roles-list li > h3 {
    margin-block-start: 0;
    font-size: 1.5rem;
    line-height: 1.05;
    letter-spacing: -0.015em;
  }
  .roles-list li > p {
    margin-top: 0.5rem;
    color: var(--color-text);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.5;
  }
  @media (prefers-reduced-motion: reduce) {
    .roles-list li { transform: none !important; }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('form[name="benevole"]');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!submitBtn) return;
      const originalText = submitBtn.textContent ?? '';
      submitBtn.disabled = true;
      submitBtn.textContent = 'En cours…';
      try {
        const response = await fetch(window.location.pathname, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
        });
        if (response.ok) {
          const aside = form.closest('aside');
          if (!aside) return;
          aside.classList.add('contact-leaving');
          setTimeout(() => {
            aside.innerHTML = `<div class="max-w-4xl mx-auto px-4 sm:px-6"><div class="contact-success" role="status" tabindex="-1"><svg class="contact-success-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg><p class="contact-success-heading">Ton inscription<br>est reçue.</p></div></div>`;
            aside.classList.remove('contact-leaving');
            aside.querySelector<HTMLElement>('[role="status"]')?.focus();
          }, 280);
        } else {
          throw new Error('server error');
        }
      } catch {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        let errorEl = form.querySelector<HTMLParagraphElement>('.form-error');
        if (!errorEl) {
          errorEl = document.createElement('p');
          errorEl.className = 'form-error';
          errorEl.setAttribute('role', 'alert');
          submitBtn.insertAdjacentElement('beforebegin', errorEl);
        }
        errorEl.textContent = '';
        errorEl.append("Ça n'a pas marché. Réessaie ou écris-nous à ");
        const mailLink = document.createElement('a');
        mailLink.href = 'mailto:info@plazey.be';
        mailLink.textContent = 'info@plazey.be';
        errorEl.append(mailLink, '.');
      }
    });
  }
</script>

<style is:global>
  .contact-leaving {
    opacity: 0;
    transform: scale(0.98);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .contact-success {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 14rem;
    padding: 3rem 0;
    gap: 0.75rem;
  }

  .contact-success-icon {
    width: 2rem;
    height: 2rem;
    color: var(--color-orange);
    opacity: 0;
    animation: success-arrive 0.4s ease-out forwards;
  }

  .contact-success-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.1;
    color: var(--color-text);
    margin: 0;
    opacity: 0;
    animation: success-arrive 0.5s 0.1s ease-out forwards;
  }

  @keyframes success-arrive {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-success-icon,
    .contact-success-heading { animation: none; opacity: 1; }
    .contact-leaving { transition: none; opacity: 1; transform: none; }
  }
</style>
