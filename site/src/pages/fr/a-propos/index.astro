---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import { Image } from 'astro:assets';
import dansPark from '../../../assets/images/dans-park.jpg';
import vrijwilligersBabyspot from '../../../assets/images/vrijwilligers-babyspot.jpg';
import vrijwilligersBar from '../../../assets/images/vrijwilligers-bar.jpg';
---

<BaseLayout title="À propos de Plazey" lang="fr" currentPath="/fr/a-propos">
  <section class="section">
    <Container>
      <h1>À propos de Plazey</h1>
      <p class="opening">Trente ans de fête de quartier au parc Élisabeth. Voilà qui le fait.</p>
      <div class="cta-group">
        <a href="#contact" class="btn-ghost">Contacte-nous</a>
      </div>
    </Container>
  </section>

  <section aria-labelledby="lhistoire" class="section">
    <Container>
      <h2 id="lhistoire">L'histoire</h2>
      <div class="flex flex-col sm:flex-row gap-8 items-start">
        <div class="flex-1">
          <p>Plazey a démarré en 1992 comme une petite fête musicale pour les riverain·es du parc Élisabeth à Koekelberg. Gratuit, en plein air, pour les voisin·es. Dans l'essence, c'est toujours ça.</p>
          <p>Au début, c'était un festival d'été classique — avec des noms qu'on voyait aussi sur d'autres scènes flamandes. Ça a changé. Plazey s'est tourné vers le quartier. La musique, les ateliers, les stands à manger : tout vient maintenant des gens qui vivent et travaillent ici. Plus de cent bénévoles le font vivre chaque année.</p>
          <p>Derrière le festival, deux maisons de quartier bruxelloises. Le nom le dit lui-même : <strong>PLAtoo</strong> à Koekelberg et <strong>ZEYp</strong> à Ganshoren.</p>
          <p>Depuis 2023, nous travaillons à ce que tout le monde puisse en faire partie. Concrètement : des bouchons d'oreilles à l'infostand, un programme en braille, et une interprète en langue des signes flamande le dimanche. Nous disons honnêtement ce qui marche et ce qui ne marche pas encore.</p>
        </div>
        <figure class="flex-1">
          <Image
            src={dansPark}
            alt="Des gens qui dansent dehors entre les arbres du parc Élisabeth, tous âges, ambiance festive."
            widths={[400, 700]}
            sizes="(max-width: 640px) 100vw, 50vw"
            class="w-full image-rounded"
          />
        </figure>
      </div>
    </Container>
  </section>

  <section aria-labelledby="qui-fait" class="section">
    <Container>
      <h2 id="qui-fait">Qui fait Plazey ?</h2>
      <p>Plazey est un projet de deux maisons de quartier bruxelloises.</p>
      <div class="org-grid grid grid-cols-1 sm:grid-cols-2 gap-8 mt-6">
        <div class="org-card">
          <h3>Maison de quartier De Platoo</h3>
          <p>Enracinée dans le quartier. Elle rassemble les gens autour de la culture, de la rencontre et du travail communautaire à Koekelberg.</p>
          <a href="https://deplatoo.be" rel="external noopener" target="_blank">En savoir plus sur De Platoo →</a>
        </div>
        <div class="org-card">
          <h3>Maison de quartier De Zeyp</h3>
          <p>Relie les habitant·es de la large ceinture nord-ouest de Bruxelles. Avec une programmation qui reflète le quartier.</p>
          <a href="https://dezeyp.be" rel="external noopener" target="_blank">En savoir plus sur De Zeyp →</a>
        </div>
      </div>
      <p class="mt-6">Plus de cent bénévoles font vivre Plazey chaque année. Derrière le bar, à la caisse, à l'infostand — et lors du montage et du démontage.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
        <figure>
          <Image
            src={vrijwilligersBabyspot}
            alt="Deux bénévoles en t-shirt rose Plazey devant la caravane Baby Spot."
            widths={[400, 700]}
            sizes="(max-width: 640px) 100vw, 50vw"
            class="w-full image-rounded"
          />
        </figure>
        <figure>
          <Image
            src={vrijwilligersBar}
            alt="Bénévoles en t-shirt rose Plazey derrière le bar, ambiance conviviale."
            widths={[400, 700]}
            sizes="(max-width: 640px) 100vw, 50vw"
            class="w-full image-rounded"
          />
        </figure>
      </div>
    </Container>
  </section>

  <section aria-labelledby="nos-partenaires" class="section">
    <Container>
      <h2 id="nos-partenaires">Nos partenaires</h2>
      <ul role="list" class="logo-wall flex flex-wrap gap-4 mt-4">
        <li><span>Demos</span></li>
        <li><span>AnySurfer</span></li>
        <li><span>Zonnelied vzw</span></li>
        <li><span>Viernulvier</span></li>
        <li><span>Club 1030 / GC De Kriekelaar</span></li>
        <li><span>Scheldeoffensief</span></li>
      </ul>
      <p class="draft-note">Liste encore à valider avant publication.</p>
    </Container>
  </section>

  <aside id="contact" aria-labelledby="contact-heading" class="callout section">
    <Container>
      <h2 id="contact-heading">Contacte-nous.</h2>
      <p>Question, idée, autre chose ? Fais-nous signe.</p>

      <div class="cta-form">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          class="flex flex-col gap-6"
        >
            <input type="hidden" name="form-name" value="contact" />
            <input type="hidden" name="origin" value="a-propos" />
            <input type="hidden" name="lang" value="fr" />

            <div class="form-field">
              <label for="contact-naam">Nom</label>
              <input
                type="text"
                id="contact-naam"
                name="naam"
                required
                autocomplete="name"
                maxlength="200"
              />
            </div>

            <div class="form-field">
              <label for="contact-email">Adresse e-mail</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                autocomplete="email"
                maxlength="254"
              />
            </div>

            <div class="form-field">
              <label for="contact-bericht">Message</label>
              <textarea
                id="contact-bericht"
                name="bericht"
                rows="4"
                required
                maxlength="2000"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary self-start">Envoie ton message</button>
          </form>
      </div>
    </Container>
  </aside>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!submitBtn) return;
      const originalText = submitBtn.textContent ?? '';
      submitBtn.disabled = true;
      submitBtn.textContent = 'En cours…';
      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
        });
        if (response.ok) {
          const successEl = document.createElement('p');
          successEl.className = 'py-4 font-semibold';
          successEl.setAttribute('role', 'status');
          successEl.setAttribute('tabindex', '-1');
          successEl.textContent = 'Merci ! On te répond dès que possible.';
          form.replaceWith(successEl);
          successEl.focus();
        } else {
          throw new Error('server error');
        }
      } catch {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        let errorEl = form.querySelector<HTMLParagraphElement>('.form-error');
        if (!errorEl) {
          errorEl = document.createElement('p');
          errorEl.className = 'form-error';
          errorEl.setAttribute('role', 'alert');
          submitBtn.insertAdjacentElement('beforebegin', errorEl);
        }
        errorEl.textContent = 'Quelque chose a mal tourné. Réessaie ou envoie un mail à info@plazey.be.';
      }
    });
  }
</script>
