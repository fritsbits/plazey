---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Partners from '../components/Partners.astro';
import { FATHOM_SITE_ID } from '../config/site';
import '../styles/global.css';

interface Props {
  title: string;
  lang: 'nl' | 'fr';
  currentPath?: string;
}
const { title, lang, currentPath = '' } = Astro.props;

const skipLabel = lang === 'fr' ? 'Aller au contenu' : 'Ga naar inhoud';
---
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Plazey</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link href="https://fonts.bunny.net/css?family=karla:400,400i,600,700|luckiest-guy:400&display=swap" rel="stylesheet" />
    {import.meta.env.PROD && (
      <script src="https://cdn.usefathom.com/script.js" data-site={FATHOM_SITE_ID} defer></script>
    )}
    <noscript>
      {/* Without JS the act lightbox can't open; show its content inline
          under the card instead, and hide the now-dead controls. */}
      <style>
        dialog.act-dialog {
          display: block;
          position: static;
          width: auto;
          max-height: none;
          margin: 0.75rem 0 0;
          overflow: visible;
        }
        dialog.act-dialog .act-close { display: none; }
        .program-card .card-more { display: none; }
      </style>
    </noscript>
  </head>
  <body class="min-h-screen flex flex-col">
    <a class="skip-link" href="#main-content">{skipLabel}</a>
    <Header lang={lang} currentPath={currentPath} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Partners lang={lang} />
    <Footer lang={lang} />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .skip-link:focus {
    position: static;
    width: auto;
    height: auto;
    overflow: visible;
    padding: 0.5rem 1rem;
  }
</style>
